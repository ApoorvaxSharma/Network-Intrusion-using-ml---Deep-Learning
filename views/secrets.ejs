<%- include('partials/header') %>
<%- include('partials/loadhead') %>

<body class="result-body">

<div id="loader"></div>

<div id="myDiv" class="result-wrapper animate-fade" style="display:none;">
  <div class="container-fluid result-container">
    <div class="row justify-content-center text-center text-light">
      <div class="col-md-8 result-card">
        <h2 class="result-title">
          🎯 Your Random Row Prediction is Ready!
        </h2>
        <p class="result-subtitle">
          Click the button below to view your result
        </p>
        <a href="/secrets_2" class="btn btn-primary result-btn">
          View Prediction Result
        </a>
      </div>
    </div>
  </div>
</div>

<script>
// Poll every second until /secrets_2 is ready (session has results),
// then show the button automatically. Max wait: 60 seconds.
let attempts = 0;
const maxAttempts = 60;

function checkReady() {
  attempts++;
  fetch('/secrets_2_ready')
    .then(r => r.json())
    .then(data => {
      if (data.ready) {
        document.getElementById("loader").style.display = "none";
        document.getElementById("myDiv").style.display = "block";
      } else if (attempts < maxAttempts) {
        setTimeout(checkReady, 1000);
      } else {
        // Timeout fallback — show button anyway
        document.getElementById("loader").style.display = "none";
        document.getElementById("myDiv").style.display = "block";
      }
    })
    .catch(() => {
      if (attempts < maxAttempts) setTimeout(checkReady, 1000);
    });
}

checkReady();
</script>

<%- include('partials/loadfoot') %>
</body>
