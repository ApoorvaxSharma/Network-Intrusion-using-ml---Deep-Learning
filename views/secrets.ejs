<%- include('partials/header') %>
<%- include('partials/loadhead') %>

<body style="margin:0;background:#f8fafc;min-height:100vh;display:flex;flex-direction:column;">

<div id="waiting-screen" style="flex:1;display:flex;align-items:center;justify-content:center;padding:40px 20px;">
  <div style="max-width:480px;width:100%;text-align:center;">

    <!-- Animated ring -->
    <div style="position:relative;width:80px;height:80px;margin:0 auto 28px;">
      <svg width="80" height="80" viewBox="0 0 80 80" style="position:absolute;top:0;left:0;animation:spin 1.2s linear infinite;">
        <circle cx="40" cy="40" r="34" fill="none" stroke="#e5e7eb" stroke-width="5"/>
        <circle cx="40" cy="40" r="34" fill="none" stroke="#0f172a" stroke-width="5"
                stroke-dasharray="60 153" stroke-linecap="round"/>
      </svg>
      <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0f172a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
    </div>

    <h2 style="font-size:20px;font-weight:700;color:#0f172a;margin:0 0 10px;">Analysing Random Network Record</h2>
    <p style="font-size:14px;color:#6b7280;line-height:1.6;margin:0 0 28px;">
      All 4 models (KNN, Random Forest, CNN, LSTM) are running inference on a randomly selected record from the NSL-KDD validation set.
    </p>

    <!-- Progress steps -->
    <div style="text-align:left;background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:20px 24px;margin-bottom:28px;">
      <div class="step" id="step1" style="display:flex;align-items:center;gap:12px;padding:8px 0;">
        <div class="step-dot" style="width:8px;height:8px;border-radius:50%;background:#d1d5db;flex-shrink:0;"></div>
        <span style="font-size:13px;color:#6b7280;">Loading validation dataset</span>
      </div>
      <div class="step" id="step2" style="display:flex;align-items:center;gap:12px;padding:8px 0;">
        <div class="step-dot" style="width:8px;height:8px;border-radius:50%;background:#d1d5db;flex-shrink:0;"></div>
        <span style="font-size:13px;color:#6b7280;">Selecting random record</span>
      </div>
      <div class="step" id="step3" style="display:flex;align-items:center;gap:12px;padding:8px 0;">
        <div class="step-dot" style="width:8px;height:8px;border-radius:50%;background:#d1d5db;flex-shrink:0;"></div>
        <span style="font-size:13px;color:#6b7280;">Running KNN &amp; Random Forest inference</span>
      </div>
      <div class="step" id="step4" style="display:flex;align-items:center;gap:12px;padding:8px 0;">
        <div class="step-dot" style="width:8px;height:8px;border-radius:50%;background:#d1d5db;flex-shrink:0;"></div>
        <span style="font-size:13px;color:#6b7280;">Running CNN &amp; LSTM inference</span>
      </div>
      <div class="step" id="step5" style="display:flex;align-items:center;gap:12px;padding:8px 0;">
        <div class="step-dot" style="width:8px;height:8px;border-radius:50%;background:#d1d5db;flex-shrink:0;"></div>
        <span style="font-size:13px;color:#6b7280;">Compiling results</span>
      </div>
    </div>

    <p id="elapsed-text" style="font-size:12px;color:#9ca3af;margin:0;">Elapsed: <span id="elapsed">0</span>s</p>
  </div>
</div>

<!-- Ready state (hidden until polling confirms) -->
<div id="ready-screen" style="flex:1;display:none;align-items:center;justify-content:center;padding:40px 20px;">
  <div style="max-width:420px;width:100%;text-align:center;">
    <div style="width:72px;height:72px;background:#dcfce7;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
    </div>
    <h2 style="font-size:20px;font-weight:700;color:#0f172a;margin:0 0 10px;">Analysis Complete</h2>
    <p style="font-size:14px;color:#6b7280;margin:0 0 28px;">All models have finished. Click below to view the full results.</p>
    <a href="/secrets_2" style="display:inline-block;padding:14px 36px;background:#0f172a;color:#fff;border-radius:999px;font-size:15px;font-weight:600;text-decoration:none;">
      View Results →
    </a>
    <br><br>
    <a href="/submit" style="font-size:13px;color:#9ca3af;text-decoration:none;">← Back to Dashboard</a>
  </div>
</div>

<style>
  @keyframes spin { to { transform: rotate(360deg); } }
  .step-dot.active { background: #0f172a !important; box-shadow: 0 0 0 3px rgba(15,23,42,0.15); }
  .step-dot.done   { background: #16a34a !important; }
</style>

<script>
  const steps = ['step1','step2','step3','step4','step5'];
  const delays = [800, 1600, 2800, 4200, 5800]; // approx when each step "activates"
  let startTime = Date.now();
  let attempts = 0;
  const maxWait = 90; // seconds

  // Animate progress steps based on elapsed time
  function animateSteps(elapsedMs) {
    steps.forEach((id, i) => {
      const dot = document.querySelector('#' + id + ' .step-dot');
      const label = document.querySelector('#' + id + ' span');
      if (elapsedMs >= delays[i]) {
        if (i < steps.length - 1 || elapsedMs >= delays[i] + 1000) {
          dot.className = 'step-dot done';
          label.style.color = '#374151';
        } else {
          dot.className = 'step-dot active';
          label.style.color = '#0f172a';
        }
      }
    });
  }

  // Update elapsed counter
  function updateElapsed() {
    const s = Math.floor((Date.now() - startTime) / 1000);
    document.getElementById('elapsed').textContent = s;
    animateSteps(Date.now() - startTime);
  }
  const elapsedTimer = setInterval(updateElapsed, 500);

  // Poll until ready
  function checkReady() {
    attempts++;
    fetch('/secrets_2_ready')
      .then(r => r.json())
      .then(data => {
        if (data.ready) {
          clearInterval(elapsedTimer);
          // Mark all steps done
          steps.forEach(id => {
            document.querySelector('#' + id + ' .step-dot').className = 'step-dot done';
            document.querySelector('#' + id + ' span').style.color = '#374151';
          });
          // Show ready screen
          document.getElementById('waiting-screen').style.display = 'none';
          const rs = document.getElementById('ready-screen');
          rs.style.display = 'flex';
        } else if (Math.floor((Date.now() - startTime) / 1000) < maxWait) {
          setTimeout(checkReady, 1000);
        } else {
          // Timeout — show button anyway
          clearInterval(elapsedTimer);
          document.getElementById('waiting-screen').style.display = 'none';
          document.getElementById('ready-screen').style.display = 'flex';
        }
      })
      .catch(() => {
        if (Math.floor((Date.now() - startTime) / 1000) < maxWait) setTimeout(checkReady, 1000);
      });
  }

  checkReady();
</script>

<%- include('partials/loadfoot') %>
</body>
