<%- include('partials/header') %>
<%- include('partials/loadhead') %>

<body onload="myFunction()" style="margin:0;">
<div id="loader"></div>

<div style="display:none;" id="myDiv" class="animate-bottom">
<div class="nids-results-page">

  <%
    /* ── Build a structured prediction object from the flat session strings ── */
    const ATTACK_DESCRIPTIONS = {
      'DOS':    'A Denial-of-Service (DoS) attack floods a machine or network to make it inaccessible. The attacker overwhelms the target with traffic, shutting out legitimate users.',
      'PROBE':  'A Probe attack scans network devices to find weaknesses in topology or open ports, gathering intelligence for future unauthorized access.',
      'R2L':    'Remote-to-Local (R2L) — an intruder sends packets to a machine where they have no local account, exploiting vulnerabilities to gain unauthorized local access.',
      'U2R':    'User-to-Root (U2R) — an attacker starts with a normal user account and escalates privileges to gain root/admin control of the system.',
      'NORMAL': 'No threat detected. Network traffic appears normal and safe.',
      'Normal': 'No threat detected. Network traffic appears normal and safe.'
    };

    function toBinary(raw) {
      if (!raw) return 'Normal';
      const s = raw.toLowerCase();
      if (s.includes('attack')) return 'Attack';
      return 'Normal';
    }

    function toType(raw) {
      if (!raw) return 'NORMAL';
      const s = raw.trim().toUpperCase();
      if (s.includes('DOS'))    return 'DOS';
      if (s.includes('PROBE'))  return 'PROBE';
      if (s.includes('R2L'))    return 'R2L';
      if (s.includes('U2R'))    return 'U2R';
      return 'NORMAL';
    }

    function toDesc(raw) {
      if (!raw || raw === 'ERROR') return 'Prediction unavailable.';
      const key = toType(raw);
      return ATTACK_DESCRIPTIONS[key] || raw;
    }

    const prediction = {
      knn:  { binary: toBinary(knn_bin_cls),  is_attack: toBinary(knn_bin_cls)  === 'Attack', attack_type: toType(knn_mul_cls),  description: toDesc(knn_mul_cls)  },
      rf:   { binary: toBinary(rf_bin_cls),   is_attack: toBinary(rf_bin_cls)   === 'Attack', attack_type: toType(rf_mul_cls),   description: toDesc(rf_mul_cls)   },
      cnn:  { binary: toBinary(cnn_bin_cls),  is_attack: toBinary(cnn_bin_cls)  === 'Attack', attack_type: toType(cnn_mul_cls),  description: toDesc(cnn_mul_cls)  },
      lstm: { binary: toBinary(lstm_bin_cls), is_attack: toBinary(lstm_bin_cls) === 'Attack', attack_type: toType(lstm_mul_cls), description: toDesc(lstm_mul_cls) }
    };

    const noData = !knn_bin_cls && !rf_bin_cls && !cnn_bin_cls && !lstm_bin_cls;

    const attackColors = {
      'DOS':    { bg:'#fff1f2', border:'#fda4af', text:'#9f1239', badge:'#e11d48' },
      'PROBE':  { bg:'#fffbeb', border:'#fcd34d', text:'#92400e', badge:'#d97706' },
      'R2L':    { bg:'#fdf4ff', border:'#e879f9', text:'#701a75', badge:'#c026d3' },
      'U2R':    { bg:'#fff7ed', border:'#fb923c', text:'#7c2d12', badge:'#ea580c' },
      'NORMAL': { bg:'#f0fdf4', border:'#86efac', text:'#14532d', badge:'#16a34a' },
      'Normal': { bg:'#f0fdf4', border:'#86efac', text:'#14532d', badge:'#16a34a' }
    };

    const modelMeta = [
      { key:'knn',  name:'K-Nearest Neighbour',         abbr:'KNN',  desc:'Instance-based — finds k most similar historical records and votes' },
      { key:'rf',   name:'Random Forest',               abbr:'RF',   desc:'Ensemble of decision trees — robust against overfitting' },
      { key:'cnn',  name:'Convolutional Neural Network',abbr:'CNN',  desc:'Detects local feature correlations in the traffic vector' },
      { key:'lstm', name:'Long Short-Term Memory',      abbr:'LSTM', desc:'Captures temporal patterns in sequential traffic flow' }
    ];

    const votes = ['knn','rf','cnn','lstm'].filter(k => prediction[k].is_attack).length;
    const overallAttack = votes >= 2;
    const topType = prediction.lstm.is_attack ? prediction.lstm.attack_type :
                    prediction.rf.is_attack   ? prediction.rf.attack_type   :
                    prediction.knn.is_attack  ? prediction.knn.attack_type  : 'NORMAL';
    const topColor = attackColors[topType] || attackColors['NORMAL'];
    const anyAttackModel = prediction.lstm.is_attack ? prediction.lstm :
                           prediction.rf.is_attack   ? prediction.rf   : prediction.knn;
  %>

  <!-- ── Page header ── -->
  <div class="nids-page-header">
    <div class="nids-header-icon" style="background:#0f172a;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
      </svg>
    </div>
    <div>
      <h1 class="nids-page-title">Random Row — Analysis Results</h1>
      <p class="nids-page-sub">A random record from the NSL-KDD validation set was selected and classified by all 4 models</p>
    </div>
  </div>

  <% if (noData) { %>
  <!-- ── No data state ── -->
  <div class="nids-error-card">
    <div class="nids-error-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
    </div>
    <div class="nids-error-body">
      <h3 class="nids-error-title">No Prediction Data</h3>
      <p class="nids-error-msg">Results haven't loaded yet. Go back and run a fresh random prediction.</p>
    </div>
  </div>
  <div class="nids-action-row">
    <a href="/secrets" class="nids-btn-primary">← Run Random Prediction</a>
    <a href="/submit" class="nids-btn-ghost">Dashboard</a>
  </div>

  <% } else { %>

  <!-- ── Verdict banner ── -->
  <div class="nids-verdict" style="background:<%= topColor.bg %>;border-color:<%= topColor.border %>;">
    <div class="nids-verdict-left">
      <div class="nids-verdict-icon-wrap" style="background:<%= topColor.badge %>;">
        <% if (overallAttack) { %>
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        <% } else { %>
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
        <% } %>
      </div>
      <div>
        <div class="nids-verdict-status" style="color:<%= topColor.text %>;">
          <%= overallAttack ? 'Threat Detected' : 'Traffic is Safe' %>
        </div>
        <div class="nids-verdict-detail" style="color:<%= topColor.text %>;">
          <% if (overallAttack) { %>
            <%= votes %>/4 models classified as <strong><%= topType %></strong> attack
          <% } else { %>
            All models agree — no malicious activity detected
          <% } %>
        </div>
      </div>
    </div>
    <div class="nids-verdict-right">
      <div class="nids-consensus-label">Model Consensus</div>
      <div class="nids-vote-bar">
        <% for(let i = 0; i < 4; i++) { %>
          <div class="nids-vote-pip <%= i < votes ? 'pip-threat' : 'pip-safe' %>"
               style="<%= i < votes ? 'background:'+topColor.badge : '' %>"></div>
        <% } %>
      </div>
      <div class="nids-vote-text" style="color:<%= topColor.text %>;"><%= votes %> of 4 flagged</div>
    </div>
  </div>

  <!-- ── Attack description ── -->
  <% if (overallAttack) { %>
  <div class="nids-desc-card" style="border-left:4px solid <%= topColor.badge %>;">
    <div class="nids-desc-type" style="color:<%= topColor.badge %>;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="margin-right:6px;"><circle cx="12" cy="12" r="10"/></svg>
      <%= topType %> Attack
    </div>
    <p class="nids-desc-text"><%= anyAttackModel.description %></p>
  </div>
  <% } %>

  <!-- ── Individual model results ── -->
  <div class="nids-models-heading">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    Individual Model Results
  </div>

  <div class="nids-model-grid">
    <% modelMeta.forEach(function(m) {
         const r = prediction[m.key];
         const c = attackColors[r.attack_type] || attackColors['NORMAL'];
    %>
    <div class="nids-model-card">
      <div class="nids-mc-header">
        <div class="nids-mc-avatar" style="background:<%= r.is_attack ? '#fee2e2' : '#dcfce7' %>;color:<%= r.is_attack ? '#991b1b' : '#14532d' %>;">
          <%= m.abbr %>
        </div>
        <div class="nids-mc-title-block">
          <div class="nids-mc-name"><%= m.name %></div>
          <div class="nids-mc-desc"><%= m.desc %></div>
        </div>
      </div>
      <div class="nids-mc-divider"></div>
      <div class="nids-mc-row">
        <span class="nids-mc-label">Binary Result</span>
        <span class="nids-mc-pill" style="background:<%= r.is_attack ? '#fee2e2' : '#dcfce7' %>;color:<%= r.is_attack ? '#991b1b' : '#14532d' %>;">
          <%= r.binary %>
        </span>
      </div>
      <div class="nids-mc-row">
        <span class="nids-mc-label">Attack Category</span>
        <span class="nids-mc-pill" style="background:<%= c.bg %>;color:<%= c.text %>;border:1px solid <%= c.border %>;">
          <%= r.attack_type %>
        </span>
      </div>
    </div>
    <% }); %>
  </div>

  <!-- ── Accuracy table ── -->
  <div class="nids-acc-section">
    <div class="nids-models-heading" style="margin-top:0;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      Model Accuracy Reference (NSL-KDD Test Set)
    </div>
    <div class="nids-acc-table-wrap">
      <table class="nids-acc-table">
        <thead>
          <tr><th>Model</th><th>Binary Accuracy</th><th>Multi-Class Accuracy</th><th>Type</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="nids-model-tag" style="background:#ede9fe;color:#5b21b6;">LSTM</span></td>
            <td><div class="nids-acc-bar-wrap"><div class="nids-acc-bar" style="width:98.7%;background:#5b21b6;"></div><span>98.7%</span></div></td>
            <td><div class="nids-acc-bar-wrap"><div class="nids-acc-bar" style="width:96.2%;background:#5b21b6;"></div><span>96.2%</span></div></td>
            <td class="nids-acc-type">Deep Learning</td>
          </tr>
          <tr>
            <td><span class="nids-model-tag" style="background:#dbeafe;color:#1e40af;">CNN</span></td>
            <td><div class="nids-acc-bar-wrap"><div class="nids-acc-bar" style="width:97.9%;background:#1e40af;"></div><span>97.9%</span></div></td>
            <td><div class="nids-acc-bar-wrap"><div class="nids-acc-bar" style="width:95.1%;background:#1e40af;"></div><span>95.1%</span></div></td>
            <td class="nids-acc-type">Deep Learning</td>
          </tr>
          <tr>
            <td><span class="nids-model-tag" style="background:#dcfce7;color:#14532d;">RF</span></td>
            <td><div class="nids-acc-bar-wrap"><div class="nids-acc-bar" style="width:97.1%;background:#16a34a;"></div><span>97.1%</span></div></td>
            <td><div class="nids-acc-bar-wrap"><div class="nids-acc-bar" style="width:94.3%;background:#16a34a;"></div><span>94.3%</span></div></td>
            <td class="nids-acc-type">ML Ensemble</td>
          </tr>
          <tr>
            <td><span class="nids-model-tag" style="background:#fef9c3;color:#854d0e;">KNN</span></td>
            <td><div class="nids-acc-bar-wrap"><div class="nids-acc-bar" style="width:95.3%;background:#ca8a04;"></div><span>95.3%</span></div></td>
            <td><div class="nids-acc-bar-wrap"><div class="nids-acc-bar" style="width:91.8%;background:#ca8a04;"></div><span>91.8%</span></div></td>
            <td class="nids-acc-type">ML Instance</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ── Actions ── -->
  <div class="nids-action-row">
    <a href="/secrets" class="nids-btn-primary">← New Random Prediction</a>
    <a href="/parameters" class="nids-btn-secondary">Manual Parameters</a>
    <a href="/submit" class="nids-btn-ghost">Dashboard</a>
  </div>

  <% } %>
</div>

<%- include('partials/footer') %>
</div>

<style>
*{box-sizing:border-box;}
.nids-results-page{max-width:860px;margin:0 auto;padding:32px 20px 60px;}

.nids-page-header{display:flex;align-items:center;gap:16px;margin-bottom:28px;padding-bottom:22px;border-bottom:1px solid #e5e7eb;}
.nids-header-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.nids-page-title{font-size:20px;font-weight:700;color:#0f172a;margin:0 0 4px;}
.nids-page-sub{font-size:13px;color:#6b7280;margin:0;}

.nids-error-card{display:flex;align-items:flex-start;gap:16px;background:#fff5f5;border:1px solid #fca5a5;border-radius:14px;padding:24px;margin-bottom:16px;}
.nids-error-icon{width:44px;height:44px;background:#fee2e2;border-radius:10px;display:flex;align-items:center;justify-content:center;color:#dc2626;flex-shrink:0;}
.nids-error-body{}
.nids-error-title{font-size:15px;font-weight:600;color:#991b1b;margin:0 0 6px;}
.nids-error-msg{font-size:13px;color:#7f1d1d;margin:0;line-height:1.6;}

.nids-verdict{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:20px;border:1px solid;border-radius:16px;padding:24px 28px;margin-bottom:16px;}
.nids-verdict-left{display:flex;align-items:center;gap:16px;}
.nids-verdict-icon-wrap{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.nids-verdict-status{font-size:20px;font-weight:700;margin-bottom:4px;}
.nids-verdict-detail{font-size:13px;opacity:.85;}
.nids-verdict-right{text-align:right;}
.nids-consensus-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;opacity:.7;margin-bottom:8px;}
.nids-vote-bar{display:flex;gap:6px;justify-content:flex-end;margin-bottom:6px;}
.nids-vote-pip{width:28px;height:8px;border-radius:999px;}
.pip-threat{background:#dc2626;}
.pip-safe{background:#d1d5db;}
.nids-vote-text{font-size:12px;font-weight:600;opacity:.85;}

.nids-desc-card{background:#fff;border-radius:12px;padding:18px 20px;margin-bottom:16px;border:1px solid #e5e7eb;}
.nids-desc-type{display:flex;align-items:center;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;}
.nids-desc-text{font-size:14px;color:#374151;line-height:1.7;margin:0;}

.nids-models-heading{display:flex;align-items:center;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:#6b7280;margin:20px 0 12px;}
.nids-model-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-bottom:20px;}
@media(max-width:580px){.nids-model-grid{grid-template-columns:1fr;}}
.nids-model-card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:18px;}
.nids-mc-header{display:flex;align-items:flex-start;gap:12px;margin-bottom:14px;}
.nids-mc-avatar{min-width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;letter-spacing:.03em;}
.nids-mc-title-block{}
.nids-mc-name{font-size:13px;font-weight:600;color:#111;margin-bottom:3px;}
.nids-mc-desc{font-size:11px;color:#9ca3af;line-height:1.4;}
.nids-mc-divider{height:1px;background:#f3f4f6;margin-bottom:12px;}
.nids-mc-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.nids-mc-label{font-size:11px;color:#9ca3af;font-weight:500;text-transform:uppercase;letter-spacing:.04em;}
.nids-mc-pill{padding:3px 10px;border-radius:999px;font-size:12px;font-weight:600;}

.nids-acc-section{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:20px;margin-bottom:24px;}
.nids-acc-table-wrap{overflow-x:auto;}
.nids-acc-table{width:100%;border-collapse:collapse;font-size:13px;}
.nids-acc-table th{text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#9ca3af;padding:8px 12px;border-bottom:1px solid #f3f4f6;}
.nids-acc-table td{padding:10px 12px;border-bottom:1px solid #f9fafb;color:#374151;vertical-align:middle;}
.nids-acc-table tr:last-child td{border-bottom:none;}
.nids-model-tag{padding:3px 10px;border-radius:6px;font-size:12px;font-weight:700;}
.nids-acc-bar-wrap{display:flex;align-items:center;gap:8px;}
.nids-acc-bar{height:6px;border-radius:999px;opacity:.8;}
.nids-acc-type{font-size:11px;color:#9ca3af;}

.nids-action-row{display:flex;gap:10px;flex-wrap:wrap;}
.nids-btn-primary{padding:12px 28px;background:#0f172a;color:#fff;border-radius:999px;font-size:14px;font-weight:600;text-decoration:none;transition:opacity .15s;}
.nids-btn-primary:hover{opacity:.85;color:#fff;}
.nids-btn-secondary{padding:12px 24px;background:#fff;color:#374151;border:1.5px solid #e5e7eb;border-radius:999px;font-size:14px;font-weight:500;text-decoration:none;transition:all .15s;}
.nids-btn-secondary:hover{border-color:#9ca3af;color:#111;}
.nids-btn-ghost{padding:12px 24px;background:transparent;color:#6b7280;border-radius:999px;font-size:14px;font-weight:500;text-decoration:none;}
.nids-btn-ghost:hover{color:#374151;}
</style>

<script>
function myFunction(){setTimeout(showPage,150);}
function showPage(){
  document.getElementById("loader").style.display="none";
  document.getElementById("myDiv").style.display="block";
}
</script>

<%- include('partials/loadfoot') %>
</body>
