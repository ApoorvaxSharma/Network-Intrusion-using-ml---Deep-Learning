<%- include('partials/header') %>
<%- include('partials/loadhead') %>

<body onload="myFunction()" style="margin:0;">

<div id="loader"></div>

<div id="myDiv" class="animate-bottom" style="display:none;">

  <div class="container-fluid prediction-wrapper">

    <div class="row prediction-row">

      <!-- KNN -->
      <div class="prediction-card">
        <div class="prediction-card-body">

          <h4 class="prediction-title">
            K-Nearest-Neighbour (KNN)
          </h4>

          <p class="prediction-text"><%=knn_bin_cls%></p>
          <p class="prediction-text"><%=knn_mul_cls%></p>
          <p class="prediction-text"><%=knn_desc%></p>

          <p class="prediction-accuracy">
            KNN Binary Class Accuracy =
            <%=knn_bin_acc%>
          </p>

          <p class="prediction-accuracy">
            KNN Multi Class Accuracy =
            <%=knn_mul_acc%>
          </p>

          <a href="/knn_bin_table"
             class="prediction-btn">
             Binary Classification Table
          </a>

          <a href="/knn_table"
             class="prediction-btn">
             Multi-Class Classification Table
          </a>

        </div>
      </div>

      <!-- Random Forest -->
      <div class="prediction-card">
        <div class="prediction-card-body">

          <h4 class="prediction-title">
            Random Forest
          </h4>

          <p class="prediction-text"><%=rf_bin_cls%></p>
          <p class="prediction-text"><%=rf_mul_cls%></p>
          <p class="prediction-text"><%=rf_desc%></p>

          <p class="prediction-accuracy">
            Random Forest Binary Accuracy =
            <%=rf_bin_acc%>
          </p>

          <p class="prediction-accuracy">
            Random Forest Multi Accuracy =
            <%=rf_mul_acc%>
          </p>

          <a href="/rf_bin_table"
             class="prediction-btn">
             Binary Classification Table
          </a>

          <a href="/rf_table"
             class="prediction-btn">
             Multi-Class Classification Table
          </a>

        </div>
      </div>

      <!-- CNN -->
      <div class="prediction-card">
        <div class="prediction-card-body">

          <h4 class="prediction-title">
            Convolutional Neural Network
          </h4>

          <p class="prediction-text"><%=cnn_bin_cls%></p>
          <p class="prediction-text"><%=cnn_mul_cls%></p>
          <p class="prediction-text"><%=cnn_desc%></p>

          <p class="prediction-accuracy">
            CNN Binary Accuracy =
            <%=cnn_bin_acc%>
          </p>

          <p class="prediction-accuracy">
            CNN Multi Accuracy =
            <%=cnn_mul_acc%>
          </p>

          <a href="/cnn_bin_table"
             class="prediction-btn">
             Binary Classification Table
          </a>

          <a href="/cnn_table"
             class="prediction-btn">
             Multi-Class Classification Table
          </a>

        </div>
      </div>

      <!-- LSTM -->
      <div class="prediction-card">
        <div class="prediction-card-body">

          <h4 class="prediction-title">
            Long Short Term Memory (LSTM)
          </h4>

          <p class="prediction-text"><%=lstm_bin_cls%></p>
          <p class="prediction-text"><%=lstm_mul_cls%></p>
          <p class="prediction-text"><%=lstm_desc%></p>

          <p class="prediction-accuracy">
            LSTM Binary Accuracy =
            <%=lstm_bin_acc%>
          </p>

          <p class="prediction-accuracy">
            LSTM Multi Accuracy =
            <%=lstm_mul_acc%>
          </p>

          <a href="/lstm_bin_table"
             class="prediction-btn">
             Binary Classification Table
          </a>

          <a href="/lstm_table"
             class="prediction-btn">
             Multi-Class Classification Table
          </a>

        </div>
      </div>

    </div>

    <!-- KEEPING LOGIN BOX SAME -->
    <div class="login-box">
      <a class="btn btn-success"
         style="text-align:center;"
         href="/submit">
         Predict Again!
      </a>

      <a class="btn btn-dark"
         style="text-align:center;background-color:#dd4b39;"
         href="/logout">
         LOGOUT
      </a>
    </div>

  </div>

  <%- include('partials/footer') %>

</div>

<script>
var myVar;

function myFunction() {
  myVar = setTimeout(showPage, 100);
}

function showPage() {
  document.getElementById("loader").style.display = "none";
  document.getElementById("myDiv").style.display = "block";
}
</script>

<%- include('partials/loadfoot') %>

</body>