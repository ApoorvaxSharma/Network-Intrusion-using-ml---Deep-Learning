<%- include('partials/header') %>
<%- include('partials/loadhead') %>

<body class="app-body">

<!-- HERO SECTION ONLY (NO NAVBAR HERE) -->
<section class="hero-section">

  <div class="container">

    <div class="hero-badge">
      NSL-KDD • LSTM • CNN • Random Forest • KNN
    </div>

    <div class="hero-grid">

      <div class="hero-text">

        <h1 class="hero-title">
          Detect <span>Network Threats</span><br>
        </h1>

        <p class="hero-subtitle">
          SecureNet is an AI-powered intrusion detection system that uses
          Machine Learning and Deep Learning models to identify cyber attacks
          in real time with high accuracy.
        </p>

        <div class="hero-buttons">

          <a href="/submit" class="btn-primary">
            Launch SecureNet →
          </a>

          <!--<a href="#features" class="btn-outline">
            Explore Features
          </a> -->

        </div>

      </div>

      <!--<div class="hero-image"> -->

        <!-- temporary -->
        <!--<img src="/css/iphone6.png"
             class="dashboard-preview"
             alt="SecureNet Dashboard"> -->

      </div>

    </div>

  </div>

</section>

<!-- FEATURES -->
<section id="models">
<section class="stats-section">

    <div class="container">

        <div class="stats-grid">

            <div class="stat-card">
                <h2>99%+</h2>
                <p>Detection Accuracy</p>
            </div>

            <div class="stat-card">
                <h2>4</h2>
                <p>ML / DL Models</p>
            </div>

            <div class="stat-card">
                <h2>23</h2>
                <p>Attack Classes</p>
            </div>

            <div class="stat-card">
                <h2>24/7</h2>
                <p>Real-Time Detection</p>
            </div>

        </div>

    </div>

</section>

<section class="features-section">

  <div class="container">

    <div class="section-title">
      <h2>Choose Your Detection Model</h2>
      <p>
        Compare Machine Learning and Deep Learning models trained on
        the NSL-KDD dataset.
      </p>
    </div>

    <div class="model-grid">

      <!-- LSTM -->
      <a href="/parameters-lstm" class="model-card">
        <div class="model-icon">⚡</div>

        <h3>LSTM</h3>

        <p>
          Captures temporal patterns in network traffic
          using recurrent neural networks.
        </p>

        <span class="accuracy-badge">
          ~99% Accuracy
        </span>
      </a>

      <!-- CNN -->
      <a href="/parameters-cnn" class="model-card">
        <div class="model-icon">◈</div>

        <h3>CNN</h3>

        <p>
          Learns spatial feature relationships
          from encoded network packets.
        </p>

        <span class="accuracy-badge">
          ~98% Accuracy
        </span>
      </a>

      <!-- RF -->
      <a href="/parameters-rf" class="model-card">
        <div class="model-icon">🌲</div>

        <h3>Random Forest</h3>

        <p>
          Ensemble learning with strong
          interpretability and robustness.
        </p>

        <span class="accuracy-badge">
          ~99% Accuracy
        </span>
      </a>

      <!-- KNN -->
      <a href="/parameters-knn" class="model-card">
        <div class="model-icon">◎</div>

        <h3>KNN</h3>

        <p>
          Distance-based classification
          ideal for benchmarking performance.
        </p>

        <span class="accuracy-badge">
          ~98% Accuracy
        </span>
      </a>

    </div>

  </div>

</section>

<section class="detection-section">

    <div class="container">

        <div class="section-title">
            <h2>Three Ways To Detect Threats</h2>
            <p>
                Analyze network traffic using multiple prediction methods.
            </p>
        </div>

        <div class="detection-grid">

            <!-- Manual -->
            <a href="/parameters" class="detection-card">

                <div class="detection-number">
                    01
                </div>

                <h3>Manual Parameters</h3>

                <p>
                    Enter all network traffic features manually and
                    get instant attack predictions.
                </p>

                <span class="detection-tag">
                    Instant Prediction
                </span>

            </a>

            <!-- CSV -->
            <a href="/csv" class="detection-card">

                <div class="detection-number">
                    02
                </div>

                <h3>CSV Upload</h3>

                <p>
                    Upload multiple network records and perform
                    batch intrusion analysis.
                </p>

                <span class="detection-tag">
                    Batch Analysis
                </span>

            </a>

            <!-- Random -->
            <a href="/submit" class="detection-card">

                <div class="detection-number">
                    03
                </div>

                <h3>Model Playground</h3>

                <p>
                    Test different ML and DL models on attack
                    classifications and compare predictions.
                </p>

                <span class="detection-tag">
                    Interactive Demo
                </span>

            </a>

        </div>

    </div>

</section>

<!-- ATTACK SECTION -->
<section id="attacks" class="attack-section">

  <div class="container">

    <div class="section-title">
      <h2>Attack Categories Detected</h2>
      <p>
        SecureNet identifies malicious traffic across multiple intrusion classes.
      </p>
    </div>

    <div class="attack-grid">

      <div class="attack-card">
        <div class="attack-icon dos"></div>

        <h3>DoS</h3>

        <p>
          Denial of Service attacks that overwhelm systems
          with excessive requests.
        </p>
      </div>

      <div class="attack-card">
        <div class="attack-icon probe"></div>

        <h3>Probe</h3>

        <p>
          Network reconnaissance attacks used to discover
          vulnerabilities and services.
        </p>
      </div>

      <div class="attack-card">
        <div class="attack-icon r2l"></div>

        <h3>R2L</h3>

        <p>
          Remote attackers gaining unauthorized local access
          to a target machine.
        </p>
      </div>

      <div class="attack-card">
        <div class="attack-icon u2r"></div>

        <h3>U2R</h3>

        <p>
          Privilege escalation attacks where normal users
          obtain root permissions.
        </p>
      </div>

      <div class="attack-card">
        <div class="attack-icon normal"></div>

        <h3>Normal Traffic</h3>

        <p>
          Legitimate network activity classified as safe
          by SecureNet.
        </p>
      </div>

    </div>

  </div>

</section>

<%- include('partials/footer') %>
<%- include('partials/loadfoot') %>

</body>