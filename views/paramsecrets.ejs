<%- include('partials/header') %>
<%- include('partials/loadhead') %>

<body class="app-body" onload="showPage()">
<div id="loader"></div>

<div id="myDiv" class="animate-bottom" style="display:none;">
<div class="nr-page">

<% if (error) { %>

  <!-- ── ERROR STATE ── -->
  <div class="nr-header">
    <div class="nr-header-icon nr-icon-threat">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
    </div>
    <div>
      <h1 class="nr-title">Analysis Failed</h1>
      <p class="nr-subtitle">The prediction script returned an error</p>
    </div>
  </div>

  <div class="nr-error-card">
    <div class="nr-error-label">Error Details</div>
    <p class="nr-error-msg"><%= error %></p>
  </div>

  <div class="nr-actions">
    <a href="/parameters" class="nr-btn nr-btn-primary">← Try Again</a>
    <a href="/submit" class="nr-btn nr-btn-ghost">Dashboard</a>
  </div>

<% } else if (prediction) { %>

  <%
    const attackColors = {
      'DOS':    { glow:'rgba(248,113,113,0.15)', accent:'#f87171', text:'rgba(248,113,113,0.9)', border:'rgba(248,113,113,0.25)' },
      'PROBE':  { glow:'rgba(251,191,36,0.15)',  accent:'#fbbf24', text:'rgba(251,191,36,0.9)',  border:'rgba(251,191,36,0.25)'  },
      'R2L':    { glow:'rgba(192,132,252,0.15)', accent:'#c084fc', text:'rgba(192,132,252,0.9)', border:'rgba(192,132,252,0.25)' },
      'U2R':    { glow:'rgba(251,146,60,0.15)',  accent:'#fb923c', text:'rgba(251,146,60,0.9)',  border:'rgba(251,146,60,0.25)'  },
      'NORMAL': { glow:'rgba(113,201,206,0.12)', accent:'#71C9CE', text:'rgba(113,201,206,0.9)', border:'rgba(113,201,206,0.25)' },
      'Normal': { glow:'rgba(113,201,206,0.12)', accent:'#71C9CE', text:'rgba(113,201,206,0.9)', border:'rgba(113,201,206,0.25)' }
    };
    const modelMeta = [
      { key:'knn',  name:'K-Nearest Neighbour', abbr:'KNN',  type:'ML',  typeColor:'rgba(113,201,206,0.15)', typeText:'#71C9CE' },
      { key:'rf',   name:'Random Forest',        abbr:'RF',   type:'ML',  typeColor:'rgba(113,201,206,0.15)', typeText:'#71C9CE' },
      { key:'cnn',  name:'Convolutional Neural Net', abbr:'CNN', type:'DL', typeColor:'rgba(36,160,237,0.15)',  typeText:'#24a0ed' },
      { key:'lstm', name:'Long Short-Term Memory',   abbr:'LSTM',type:'DL', typeColor:'rgba(36,160,237,0.15)',  typeText:'#24a0ed' }
    ];
    const votes = ['knn','rf','cnn','lstm'].filter(k => prediction[k] && prediction[k].is_attack).length;
    const overallAttack = votes >= 2;
    const topType = (prediction.lstm && prediction.lstm.is_attack) ? prediction.lstm.attack_type :
                    (prediction.rf   && prediction.rf.is_attack)   ? prediction.rf.attack_type :
                    (prediction.knn  && prediction.knn.is_attack)  ? prediction.knn.attack_type : 'NORMAL';
    const topC = attackColors[topType] || attackColors['NORMAL'];
    const anyAttackModel = (prediction.lstm && prediction.lstm.is_attack) ? prediction.lstm :
                           (prediction.rf   && prediction.rf.is_attack)   ? prediction.rf   : prediction.knn;
  %>

  <!-- ── Page header ── -->
  <div class="nr-header">
    <div class="nr-header-icon" style="background:rgba(0,173,181,0.15);border-color:rgba(0,173,181,0.3);color:#71C9CE;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
      </svg>
    </div>
    <div class="nr-header-text">
      <h1 class="nr-title">Traffic Analysis Results</h1>
      <p class="nr-subtitle">All 4 models have been evaluated · NSL-KDD feature set</p>
    </div>
    <div class="nr-header-actions">
      <a href="/parameters" class="nr-btn nr-btn-ghost">← New Analysis</a>
      <a href="/submit" class="nr-btn nr-btn-ghost">Dashboard</a>
    </div>
  </div>

  <!-- ── Verdict banner ── -->
  <div class="nr-verdict" style="background:linear-gradient(135deg,<%= topC.glow %>,rgba(255,255,255,0.02));border-color:<%= topC.border %>;">

    <div class="nr-verdict-left">
      <div class="nr-verdict-icon" style="background:<%= topC.glow %>;border:1px solid <%= topC.border %>;">
        <% if (overallAttack) { %>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="<%= topC.accent %>" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        <% } else { %>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="<%= topC.accent %>" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
        <% } %>
      </div>
      <div>
        <div class="nr-verdict-status" style="color:<%= topC.text %>;">
          <%= overallAttack ? 'Threat Detected' : 'Traffic is Safe' %>
        </div>
        <div class="nr-verdict-detail">
          <% if (overallAttack) { %>
            <%= votes %>/4 models classified as <span style="color:<%= topC.text %>;font-weight:600;"><%= topType %></span> attack
          <% } else { %>
            All models agree — no malicious activity detected
          <% } %>
        </div>
      </div>
    </div>

    <div class="nr-vote-block">
      <div class="nr-vote-label">Model Consensus</div>
      <div class="nr-vote-pips">
        <% for(let i=0;i<4;i++) { %>
          <div class="nr-pip" style="background:<%= i < votes ? topC.accent : 'rgba(255,255,255,0.12)' %>;box-shadow:<%= i < votes ? '0 0 6px '+topC.accent+'88' : 'none' %>;"></div>
        <% } %>
      </div>
      <div class="nr-vote-text" style="color:<%= topC.text %>;"><%= votes %> of 4 flagged</div>
    </div>

  </div>

  <!-- ── Attack description ── -->
  <% if (overallAttack && anyAttackModel) { %>
  <div class="nr-desc-card" style="border-left-color:<%= topC.accent %>;">
    <div class="nr-desc-type" style="color:<%= topC.text %>;">
      <span class="nr-desc-dot" style="background:<%= topC.accent %>;box-shadow:0 0 6px <%= topC.accent %>88;"></span>
      <%= topType %> Attack
    </div>
    <p class="nr-desc-text"><%= anyAttackModel.description %></p>
  </div>
  <% } %>

  <!-- ── Model results grid ── -->
  <div class="nr-section-label">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    Individual Model Results
  </div>

  <div class="nr-model-grid">
  <% modelMeta.forEach(function(m) {
       if (!prediction[m.key]) return;
       const r = prediction[m.key];
       const rc = attackColors[r.attack_type] || attackColors['NORMAL'];
       const isAtk = r.is_attack;
  %>
    <div class="nr-model-card" style="<%= isAtk ? 'border-top:2px solid '+rc.accent+';' : '' %>">
      <div class="nr-mc-head">
        <div class="nr-mc-avatar" style="background:<%= isAtk ? 'rgba(248,113,113,0.12)' : 'rgba(113,201,206,0.10)' %>;color:<%= isAtk ? '#f87171' : '#71C9CE' %>;">
          <%= m.abbr %>
        </div>
        <div class="nr-mc-info">
          <div class="nr-mc-name"><%= m.name %></div>
          <span class="nr-mc-type" style="background:<%= m.typeColor %>;color:<%= m.typeText %>;"><%= m.type %></span>
        </div>
        <div class="nr-mc-verdict-pill" style="background:<%= isAtk ? 'rgba(248,113,113,0.12)' : 'rgba(113,201,206,0.10)' %>;color:<%= isAtk ? '#f87171' : '#71C9CE' %>;border:1px solid <%= isAtk ? 'rgba(248,113,113,0.25)' : 'rgba(113,201,206,0.25)' %>;">
          <%= r.binary %>
        </div>
      </div>
      <div class="nr-mc-divider"></div>
      <div class="nr-mc-row">
        <span class="nr-mc-label">Attack Category</span>
        <span class="nr-mc-val" style="color:<%= rc.text %>"><%= r.attack_type %></span>
      </div>
      <div class="nr-table-links">
        <a href="/<%= m.key === 'rf' ? 'rf' : m.key %>_bin_table" class="nr-table-link">Binary Table</a>
        <a href="/<%= m.key === 'rf' ? 'rf' : m.key %>_table" class="nr-table-link">Multi-class Table</a>
      </div>
    </div>
  <% }); %>
  </div>

  <!-- ── Accuracy reference table ── -->
  <div class="nr-section-label">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
    Model Accuracy Reference · NSL-KDD Test Set
  </div>

  <div class="nr-acc-card">
    <% const accData = [
      { name:'LSTM', abbr:'LSTM', bin:'98.7', multi:'96.2', w: 98.7, type:'Deep Learning', tc:'#24a0ed' },
      { name:'CNN',  abbr:'CNN',  bin:'97.9', multi:'95.1', w: 97.9, type:'Deep Learning', tc:'#24a0ed' },
      { name:'RF',   abbr:'RF',   bin:'97.1', multi:'94.3', w: 97.1, type:'ML Ensemble',  tc:'#71C9CE' },
      { name:'KNN',  abbr:'KNN',  bin:'95.3', multi:'91.8', w: 95.3, type:'ML Instance',  tc:'#71C9CE' }
    ]; %>
    <% accData.forEach(function(a) { %>
    <div class="nr-acc-row">
      <span class="nr-acc-model" style="color:<%= a.tc %>;"><%= a.abbr %></span>
      <span class="nr-acc-type"><%= a.type %></span>
      <div class="nr-acc-bars">
        <div class="nr-acc-bar-row">
          <span class="nr-acc-bar-label">Binary</span>
          <div class="nr-acc-bar-track">
            <div class="nr-acc-bar-fill" style="width:<%= a.bin %>%;background:<%= a.tc %>;"></div>
          </div>
          <span class="nr-acc-val"><%= a.bin %>%</span>
        </div>
        <div class="nr-acc-bar-row">
          <span class="nr-acc-bar-label">Multi</span>
          <div class="nr-acc-bar-track">
            <div class="nr-acc-bar-fill" style="width:<%= a.multi %>%;background:<%= a.tc %>;opacity:0.65;"></div>
          </div>
          <span class="nr-acc-val"><%= a.multi %>%</span>
        </div>
      </div>
    </div>
    <% }); %>
  </div>

  <!-- ── Actions ── -->
  <div class="nr-actions">
    <a href="/parameters" class="nr-btn nr-btn-primary">← New Analysis</a>
    <a href="/secrets" class="nr-btn nr-btn-ghost">Random Row Predict</a>
    <a href="/submit" class="nr-btn nr-btn-ghost">Dashboard</a>
  </div>

<% } else { %>

  <!-- No prediction yet (direct GET to /paramsecrets) -->
  <div class="nr-header">
    <div class="nr-header-icon" style="background:rgba(0,173,181,0.15);border-color:rgba(0,173,181,0.3);color:#71C9CE;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </div>
    <div>
      <h1 class="nr-title">No Results Yet</h1>
      <p class="nr-subtitle">Submit the parameter form to run an analysis</p>
    </div>
  </div>
  <div class="nr-actions" style="margin-top:24px;">
    <a href="/parameters" class="nr-btn nr-btn-primary">Go to Parameter Input</a>
    <a href="/submit" class="nr-btn nr-btn-ghost">Dashboard</a>
  </div>

<% } %>

</div>
<%- include('partials/footer') %>
</div>

<style>
.nr-page {
  max-width: 860px;
  margin: 0 auto;
  padding: 32px 20px 60px;
  font-family: "Montserrat", sans-serif;
  color: #fff;
}

/* Header */
.nr-header {
  display: flex; align-items: center; gap: 14px;
  margin-bottom: 22px; flex-wrap: wrap;
}
.nr-header-icon {
  width: 46px; height: 46px; border-radius: 12px;
  border: 1px solid;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.nr-icon-threat { background:rgba(248,113,113,0.15);border-color:rgba(248,113,113,0.3);color:#f87171; }
.nr-header-text { flex: 1; min-width: 0; }
.nr-title { font-size: 20px; font-weight: 700; color:#fff; margin: 0 0 3px; letter-spacing:-0.3px; }
.nr-subtitle { font-size: 13px; color: rgba(255,255,255,0.45); margin: 0; }
.nr-header-actions { display: flex; gap: 8px; }

/* Error */
.nr-error-card {
  background: rgba(248,113,113,0.07);
  border: 1px solid rgba(248,113,113,0.2);
  border-radius: 12px; padding: 18px 20px;
  margin-bottom: 18px;
}
.nr-error-label {
  font-size: 10px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: #f87171; margin-bottom: 8px; font-family: monospace;
}
.nr-error-msg { font-size: 13px; color: rgba(255,255,255,0.7); line-height: 1.6; margin: 0; word-break: break-word; }

/* Verdict banner */
.nr-verdict {
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 18px;
  border: 1px solid; border-radius: 14px;
  padding: 22px 24px; margin-bottom: 14px;
  backdrop-filter: blur(10px);
}
.nr-verdict-left { display: flex; align-items: center; gap: 16px; }
.nr-verdict-icon {
  width: 50px; height: 50px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.nr-verdict-status { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
.nr-verdict-detail { font-size: 13px; color: rgba(255,255,255,0.55); }
.nr-vote-block { text-align: right; }
.nr-vote-label {
  font-size: 10px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.08em; color: rgba(255,255,255,0.35); margin-bottom: 8px;
}
.nr-vote-pips { display: flex; gap: 6px; justify-content: flex-end; margin-bottom: 6px; }
.nr-pip { width: 30px; height: 7px; border-radius: 99px; transition: all 0.3s; }
.nr-vote-text { font-size: 12px; font-weight: 600; }

/* Description */
.nr-desc-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-left: 3px solid;
  border-radius: 12px; padding: 16px 20px;
  margin-bottom: 14px;
  backdrop-filter: blur(8px);
}
.nr-desc-type {
  display: flex; align-items: center; gap: 8px;
  font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; margin-bottom: 8px; font-family: monospace;
}
.nr-desc-dot { width: 6px; height: 6px; border-radius: 50%; }
.nr-desc-text { font-size: 13px; color: rgba(255,255,255,0.65); line-height: 1.7; margin: 0; }

/* Section label */
.nr-section-label {
  display: flex; align-items: center; gap: 8px;
  font-size: 10px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.12em; color: rgba(255,255,255,0.35);
  margin: 22px 0 12px; font-family: monospace;
}

/* Model grid */
.nr-model-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 12px; margin-bottom: 0; }
@media(max-width:560px) { .nr-model-grid { grid-template-columns: 1fr; } }

.nr-model-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px; padding: 16px;
  backdrop-filter: blur(8px);
  transition: transform 0.2s, box-shadow 0.2s;
}
.nr-model-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }

.nr-mc-head { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
.nr-mc-avatar {
  min-width: 40px; height: 40px; border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700; letter-spacing: 0.05em; font-family: monospace;
}
.nr-mc-info { flex: 1; min-width: 0; }
.nr-mc-name { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.85); margin-bottom: 3px; }
.nr-mc-type {
  display: inline-block; font-size: 9px; font-weight: 700;
  padding: 2px 7px; border-radius: 3px; font-family: monospace;
  letter-spacing: 0.06em;
}
.nr-mc-verdict-pill {
  padding: 4px 10px; border-radius: 99px;
  font-size: 11px; font-weight: 700; white-space: nowrap;
}
.nr-mc-divider { height: 1px; background: rgba(255,255,255,0.06); margin-bottom: 12px; }
.nr-mc-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.nr-mc-label { font-size: 10px; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.07em; font-family: monospace; }
.nr-mc-val { font-size: 12px; font-weight: 600; }
.nr-table-links { display: flex; gap: 6px; flex-wrap: wrap; }
.nr-table-link {
  font-size: 10px; font-family: monospace; font-weight: 600;
  color: rgba(255,255,255,0.35); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 4px; padding: 4px 9px; text-decoration: none;
  letter-spacing: 0.05em; transition: all 0.15s;
}
.nr-table-link:hover { border-color: rgba(113,201,206,0.4); color: #71C9CE; }

/* Accuracy card */
.nr-acc-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px; padding: 4px 0;
  backdrop-filter: blur(8px); margin-bottom: 0;
}
.nr-acc-row {
  display: flex; align-items: center; gap: 14px;
  padding: 14px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.nr-acc-row:last-child { border-bottom: none; }
.nr-acc-model { font-family: monospace; font-size: 11px; font-weight: 700; width: 36px; flex-shrink: 0; }
.nr-acc-type { font-size: 10px; color: rgba(255,255,255,0.3); width: 90px; flex-shrink: 0; }
.nr-acc-bars { flex: 1; display: flex; flex-direction: column; gap: 5px; }
.nr-acc-bar-row { display: flex; align-items: center; gap: 8px; }
.nr-acc-bar-label { font-size: 9px; color: rgba(255,255,255,0.3); width: 30px; font-family: monospace; flex-shrink: 0; }
.nr-acc-bar-track { flex: 1; height: 4px; background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden; }
.nr-acc-bar-fill { height: 100%; border-radius: 2px; }
.nr-acc-val { font-size: 10px; font-family: monospace; color: rgba(255,255,255,0.55); width: 36px; text-align: right; flex-shrink: 0; }

/* Actions */
.nr-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 24px; }

/* Buttons */
.nr-btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 10px 18px; border-radius: 8px;
  font-size: 13px; font-weight: 600;
  font-family: "Montserrat", sans-serif;
  text-decoration: none; cursor: pointer; border: none;
  transition: all 0.18s; white-space: nowrap;
}
.nr-btn-primary { background: #00ADB5; color: #fff; }
.nr-btn-primary:hover { background: #00c4cd; box-shadow: 0 0 18px rgba(0,173,181,0.35); color: #fff; }
.nr-btn-ghost {
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.6);
  border: 1px solid rgba(255,255,255,0.1);
}
.nr-btn-ghost:hover { background: rgba(255,255,255,0.1); color: #fff; }
</style>

<script>
function showPage() {
  document.getElementById("loader").style.display = "none";
  document.getElementById("myDiv").style.display = "block";
}
</script>

<%- include('partials/loadfoot') %>
</body>
