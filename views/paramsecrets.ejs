<%- include('partials/header') %>
<%- include('partials/loadhead') %>

<body onload="myFunction()" style="margin:0;">
<div id="loader"></div>

<div style="display:none;" id="myDiv" class="animate-bottom">
<div class="container-fluid py-4 px-3 px-md-5" style="max-width:1100px;margin:0 auto;">

<% if (error) { %>
  <div class="alert-box">
    <div class="alert-icon">&#9888;</div>
    <div>
      <strong>Prediction Error</strong>
      <p style="margin:4px 0 0;font-size:14px;opacity:0.85;"><%= error %></p>
    </div>
  </div>
  <div class="text-center mt-4">
    <a href="/parameters" class="btn-back">&#8592; Try Again</a>
  </div>

<% } else if (prediction) { %>

  <!-- Verdict Banner -->
  <div class="verdict-banner <%= prediction.verdict.is_attack ? 'verdict-attack' : 'verdict-safe' %>">
    <div class="verdict-icon"><%= prediction.verdict.is_attack ? '⚠' : '✓' %></div>
    <div class="verdict-text">
      <h2><%= prediction.verdict.is_attack ? 'Threat Detected' : 'Traffic is Safe' %></h2>
      <p><%= prediction.verdict.confidence %></p>
    </div>
    <div class="verdict-badge"><%= prediction.verdict.is_attack ? 'ATTACK' : 'NORMAL' %></div>
  </div>

  <!-- Model Results Grid -->
  <div class="models-grid">

    <% const models = [
      { key: 'knn',  name: 'K-Nearest Neighbour', short: 'KNN',  icon: 'K' },
      { key: 'rf',   name: 'Random Forest',        short: 'RF',   icon: 'R' },
      { key: 'cnn',  name: 'Convolutional Neural Network', short: 'CNN', icon: 'C' },
      { key: 'lstm', name: 'Long Short-Term Memory', short: 'LSTM', icon: 'L' }
    ]; %>

    <% models.forEach(function(m) {
      const r = prediction[m.key];
    %>
    <div class="model-card <%= r.is_attack ? 'card-attack' : 'card-safe' %>">
      <div class="card-header-row">
        <div class="model-avatar <%= r.is_attack ? 'avatar-attack' : 'avatar-safe' %>">
          <%= m.icon %>
        </div>
        <div>
          <div class="model-name"><%= m.name %></div>
          <div class="model-short"><%= m.short %></div>
        </div>
        <div class="card-verdict-pill <%= r.is_attack ? 'pill-attack' : 'pill-safe' %>">
          <%= r.binary %>
        </div>
      </div>

      <div class="card-divider"></div>

      <div class="card-row">
        <span class="card-label">Attack Type</span>
        <span class="card-value <%= r.is_attack ? 'value-attack' : 'value-safe' %>"><%= r.attack_type %></span>
      </div>

      <div class="card-description">
        <%= r.description %>
      </div>
    </div>
    <% }); %>

  </div>

  <!-- Action Row -->
  <div class="action-row">
    <a href="/parameters" class="btn-back">&#8592; New Prediction</a>
    <a href="/submit" class="btn-dashboard">Dashboard</a>
  </div>

<% } %>
</div>
<%- include('partials/footer') %>
</div>

<style>
.verdict-banner{display:flex;align-items:center;gap:20px;border-radius:14px;padding:24px 28px;margin-bottom:32px;border:1px solid transparent;}
.verdict-attack{background:#fff5f5;border-color:#fca5a5;}
.verdict-safe{background:#f0fdf4;border-color:#86efac;}
.verdict-icon{font-size:36px;line-height:1;}
.verdict-attack .verdict-icon{color:#dc2626;}
.verdict-safe .verdict-icon{color:#16a34a;}
.verdict-text h2{margin:0 0 4px;font-size:22px;font-weight:600;}
.verdict-attack .verdict-text h2{color:#991b1b;}
.verdict-safe .verdict-text h2{color:#14532d;}
.verdict-text p{margin:0;font-size:14px;}
.verdict-attack .verdict-text p{color:#b91c1c;}
.verdict-safe .verdict-text p{color:#166534;}
.verdict-badge{margin-left:auto;padding:6px 18px;border-radius:999px;font-size:13px;font-weight:700;letter-spacing:.06em;}
.verdict-attack .verdict-badge{background:#dc2626;color:#fff;}
.verdict-safe .verdict-badge{background:#16a34a;color:#fff;}

.models-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:18px;margin-bottom:28px;}
.model-card{background:#fff;border-radius:14px;padding:20px;border:1px solid #e5e7eb;transition:box-shadow .2s;}
.model-card:hover{box-shadow:0 4px 20px rgba(0,0,0,.08);}
.card-attack{border-left:4px solid #dc2626;}
.card-safe{border-left:4px solid #16a34a;}

.card-header-row{display:flex;align-items:center;gap:12px;margin-bottom:14px;}
.model-avatar{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;flex-shrink:0;}
.avatar-attack{background:#fee2e2;color:#991b1b;}
.avatar-safe{background:#dcfce7;color:#14532d;}
.model-name{font-size:13px;font-weight:600;color:#111;line-height:1.3;}
.model-short{font-size:11px;color:#6b7280;margin-top:2px;}
.card-verdict-pill{margin-left:auto;padding:4px 12px;border-radius:999px;font-size:12px;font-weight:600;white-space:nowrap;}
.pill-attack{background:#fee2e2;color:#991b1b;}
.pill-safe{background:#dcfce7;color:#14532d;}

.card-divider{height:1px;background:#f3f4f6;margin:0 0 14px;}
.card-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
.card-label{font-size:12px;color:#6b7280;font-weight:500;text-transform:uppercase;letter-spacing:.04em;}
.card-value{font-size:13px;font-weight:700;}
.value-attack{color:#dc2626;}
.value-safe{color:#16a34a;}
.card-description{font-size:12.5px;color:#4b5563;line-height:1.6;border-top:1px solid #f3f4f6;padding-top:12px;margin-top:4px;}

.alert-box{display:flex;align-items:flex-start;gap:16px;background:#fff5f5;border:1px solid #fca5a5;border-radius:12px;padding:20px 24px;margin:24px 0;}
.alert-icon{font-size:24px;color:#dc2626;margin-top:2px;}

.action-row{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.btn-back,.btn-dashboard{padding:11px 28px;border-radius:999px;font-size:14px;font-weight:600;text-decoration:none;transition:opacity .15s;}
.btn-back{background:#f3f4f6;color:#374151;border:1px solid #e5e7eb;}
.btn-back:hover{opacity:.8;}
.btn-dashboard{background:#1e293b;color:#fff;}
.btn-dashboard:hover{opacity:.85;}
</style>

<script>
function myFunction(){setTimeout(showPage,150);}
function showPage(){
  document.getElementById("loader").style.display="none";
  document.getElementById("myDiv").style.display="block";
}
</script>

<%- include('partials/loadfoot') %>
</body>
