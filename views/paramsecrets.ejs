<%- include('partials/header') %>
<%- include('partials/loadhead') %>

<body class="app-body" onload="showPage()">
<div id="loader"></div>

<div id="myDiv" class="animate-bottom" style="display:none;">
<div class="nr-page">

<% if (error) { %>

  <!-- ══════════════════════════════════════
       ERROR STATE
  ══════════════════════════════════════ -->
  <div class="nr-header">
    <div class="nr-header-icon nr-icon-danger">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
    </div>
    <div>
      <h1 class="nr-title">Analysis Failed</h1>
      <p class="nr-subtitle">The prediction script returned an error — check input values and model paths</p>
    </div>
  </div>

  <div class="nr-error-card">
    <div class="nr-error-label">Error Details</div>
    <p class="nr-error-msg"><%= error %></p>
  </div>

  <div class="nr-actions">
    <a href="/parameters" class="nr-btn nr-btn-primary">← Try Again</a>
    <a href="/submit" class="nr-btn nr-btn-ghost">Dashboard</a>
  </div>

<% } else if (prediction) { %>

  <%
    /* ── Colour palette per attack type ── */
    const COLORS = {
      'DOS':    { bg:'rgba(248,113,113,0.12)', accent:'#f87171', border:'rgba(248,113,113,0.25)', text:'rgba(248,113,113,0.9)' },
      'PROBE':  { bg:'rgba(251,191,36,0.12)',  accent:'#fbbf24', border:'rgba(251,191,36,0.25)',  text:'rgba(251,191,36,0.9)'  },
      'R2L':    { bg:'rgba(192,132,252,0.12)', accent:'#c084fc', border:'rgba(192,132,252,0.25)', text:'rgba(192,132,252,0.9)' },
      'U2R':    { bg:'rgba(251,146,60,0.12)',  accent:'#fb923c', border:'rgba(251,146,60,0.25)',  text:'rgba(251,146,60,0.9)'  },
      'NORMAL': { bg:'rgba(113,201,206,0.10)', accent:'#71C9CE', border:'rgba(113,201,206,0.25)', text:'rgba(113,201,206,0.9)' },
      'Normal': { bg:'rgba(113,201,206,0.10)', accent:'#71C9CE', border:'rgba(113,201,206,0.25)', text:'rgba(113,201,206,0.9)' }
    };

    /* ── Model metadata ── */
    const MODELS = [
      { key:'knn',  name:'K-Nearest Neighbour',     abbr:'KNN',  family:'ML',  fc:'rgba(113,201,206,0.15)', ft:'#71C9CE', binRoute:'knn_bin_table',  multiRoute:'knn_table'  },
      { key:'rf',   name:'Random Forest',            abbr:'RF',   family:'ML',  fc:'rgba(113,201,206,0.15)', ft:'#71C9CE', binRoute:'rf_bin_table',   multiRoute:'rf_table'   },
      { key:'cnn',  name:'Convolutional Neural Net', abbr:'CNN',  family:'DL',  fc:'rgba(36,160,237,0.15)',  ft:'#24a0ed', binRoute:'cnn_bin_table',  multiRoute:'cnn_table'  },
      { key:'lstm', name:'Long Short-Term Memory',   abbr:'LSTM', family:'DL',  fc:'rgba(36,160,237,0.15)',  ft:'#24a0ed', binRoute:'lstm_bin_table', multiRoute:'lstm_table' }
    ];

    /* ── Voting & overall verdict ── */
    const votes       = MODELS.filter(m => prediction[m.key] && prediction[m.key].is_attack).length;
    const overallAtk  = votes >= 2;

    /* Pick attack type from most trusted model (LSTM > RF > CNN > KNN) */
    const topModel   = ['lstm','rf','cnn','knn'].find(k => prediction[k] && prediction[k].is_attack);
    const topType    = topModel ? prediction[topModel].attack_type : 'NORMAL';
    const topC       = COLORS[topType] || COLORS['NORMAL'];
    const anyAtkData = topModel ? prediction[topModel] : null;

    /* ── Accuracy reference data ── */
    const ACC = [
      { abbr:'LSTM', name:'Long Short-Term Memory', family:'Deep Learning', bin:'98.7', multi:'96.2', tc:'#24a0ed' },
      { abbr:'CNN',  name:'Convolutional Neural Net', family:'Deep Learning', bin:'97.9', multi:'95.1', tc:'#24a0ed' },
      { abbr:'RF',   name:'Random Forest',             family:'ML Ensemble',  bin:'97.1', multi:'94.3', tc:'#71C9CE' },
      { abbr:'KNN',  name:'K-Nearest Neighbour',       family:'ML Instance',  bin:'95.3', multi:'91.8', tc:'#71C9CE' }
    ];
  %>

  <!-- ══════════════════════════════════════
       PAGE HEADER
  ══════════════════════════════════════ -->
  <div class="nr-header">
    <div class="nr-header-icon" style="background:rgba(0,173,181,0.15);border-color:rgba(0,173,181,0.3);color:#71C9CE;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
      </svg>
    </div>
    <div class="nr-header-text">
      <h1 class="nr-title">Traffic Analysis Results</h1>
      <p class="nr-subtitle">All 4 models evaluated · NSL-KDD feature set · Binary + Multi-class</p>
    </div>
    <div class="nr-header-actions">
      <a href="/parameters" class="nr-btn nr-btn-ghost">← New Analysis</a>
      <a href="/submit" class="nr-btn nr-btn-ghost">Dashboard</a>
    </div>
  </div>

  <!-- ══════════════════════════════════════
       VERDICT BANNER
  ══════════════════════════════════════ -->
  <div class="nr-verdict" style="background:<%=topC.bg%>;border-color:<%=topC.border%>;">

    <div class="nr-verdict-left">
      <div class="nr-verdict-icon" style="background:<%=topC.bg%>;border:1px solid <%=topC.border%>;">
        <% if (overallAtk) { %>
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="<%= topC.accent %>" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        <% } else { %>
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="<%= topC.accent %>" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
        <% } %>
      </div>

      <div>
        <div class="nr-verdict-status" style="color:<%=topC.text%>;">
          <%= overallAtk ? 'Threat Detected' : 'Traffic is Safe' %>
        </div>
        <div class="nr-verdict-detail">
          <% if (overallAtk) { %>
            <%= votes %>/4 models classified as
            <span style="color:<%=topC.text%>;font-weight:700;"><%=topType%></span> attack
          <% } else { %>
            Majority consensus — no malicious activity detected
          <% } %>
        </div>
        <% if (overallAtk && anyAtkData && anyAtkData.description) { %>
          <div class="nr-verdict-desc"><%=anyAtkData.description%></div>
        <% } %>
      </div>
    </div>

    <!-- Consensus pips -->
    <div class="nr-vote-block">
      <div class="nr-vote-label">Model Consensus</div>
      <div class="nr-vote-pips">
        <% for (let i = 0; i < 4; i++) { %>
          <div class="nr-pip" style="
            background: <%= i < votes ? topC.accent : 'rgba(255,255,255,0.10)' %>;
            box-shadow: <%= i < votes ? '0 0 8px ' + topC.accent + '88' : 'none' %>;
          "></div>
        <% } %>
      </div>
      <div class="nr-vote-fraction" style="color:<%=topC.text%>;"><%=votes%> of 4 flagged</div>
      <div class="nr-vote-note"><%= overallAtk ? 'Threat likely' : 'Traffic normal' %></div>
    </div>

  </div>

  <!-- ══════════════════════════════════════
       INDIVIDUAL MODEL RESULTS
  ══════════════════════════════════════ -->
  <div class="nr-section-label">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    Individual Model Results
  </div>

  <div class="nr-model-grid">
  <% MODELS.forEach(function(m) {
       if (!prediction[m.key]) return;
       const r   = prediction[m.key];
       const rc  = COLORS[r.attack_type] || COLORS['NORMAL'];
       const isA = r.is_attack;
  %>
    <div class="nr-model-card" style="<%= isA ? 'border-top: 2px solid ' + rc.accent + ';' : '' %>">

      <div class="nr-mc-head">
        <!-- Model avatar -->
        <div class="nr-mc-avatar" style="background:<%=isA?'rgba(248,113,113,0.12)':'rgba(113,201,206,0.10)'%>;color:<%=isA?'#f87171':'#71C9CE'%>;">
          <%=m.abbr%>
        </div>

        <div class="nr-mc-info">
          <div class="nr-mc-name"><%=m.name%></div>
          <span class="nr-mc-family" style="background:<%=m.fc%>;color:<%=m.ft%>;"><%=m.family%></span>
        </div>

        <!-- Binary verdict pill -->
        <div class="nr-mc-verdict"
          style="background:<%=isA?'rgba(248,113,113,0.12)':'rgba(113,201,206,0.10)'%>;
                 color:<%=isA?'#f87171':'#71C9CE'%>;
                 border:1px solid <%=isA?'rgba(248,113,113,0.25)':'rgba(113,201,206,0.25)'%>;">
          <%=r.binary%>
        </div>
      </div>

      <div class="nr-mc-divider"></div>

      <!-- Attack category -->
      <div class="nr-mc-row">
        <span class="nr-mc-lbl">Attack category</span>
        <span class="nr-mc-val" style="color:<%=rc.text%>;"><%=r.attack_type%></span>
      </div>

      <!-- Confidence if available -->
      <% if (r.confidence !== undefined && r.confidence !== null) { %>
      <div class="nr-mc-row" style="margin-top:8px;">
        <span class="nr-mc-lbl">Confidence</span>
        <div class="nr-mc-conf-bar">
          <div class="nr-mc-conf-fill" style="width:<%=r.confidence%>%;background:<%=isA?rc.accent:'#71C9CE'%>;"></div>
        </div>
        <span class="nr-mc-conf-pct" style="color:<%=isA?rc.text:'rgba(113,201,206,0.8)'%>;"><%=r.confidence%>%</span>
      </div>
      <% } %>

      <!-- Table links -->
      <div class="nr-mc-links">
        <a href="/<%=m.binRoute%>" class="nr-mc-link">Binary table</a>
        <a href="/<%=m.multiRoute%>" class="nr-mc-link">Multi-class table</a>
      </div>

    </div>
  <% }); %>
  </div>

  <!-- ══════════════════════════════════════
       MODEL ACCURACY REFERENCE
  ══════════════════════════════════════ -->
  <div class="nr-section-label" style="margin-top:24px;">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
    Model Accuracy Reference · NSL-KDD Test Set
  </div>

  <div class="nr-acc-card">
    <% ACC.forEach(function(a) { %>
    <div class="nr-acc-row">
      <div class="nr-acc-left">
        <span class="nr-acc-abbr" style="color:<%=a.tc%>;"><%=a.abbr%></span>
        <span class="nr-acc-family"><%=a.family%></span>
      </div>
      <div class="nr-acc-bars">
        <div class="nr-acc-bar-row">
          <span class="nr-acc-bar-lbl">Binary</span>
          <div class="nr-acc-track">
            <div class="nr-acc-fill" style="width:<%=a.bin%>%;background:<%=a.tc%>;"></div>
          </div>
          <span class="nr-acc-pct"><%=a.bin%>%</span>
        </div>
        <div class="nr-acc-bar-row">
          <span class="nr-acc-bar-lbl">Multi</span>
          <div class="nr-acc-track">
            <div class="nr-acc-fill" style="width:<%=a.multi%>%;background:<%=a.tc%>;opacity:0.6;"></div>
          </div>
          <span class="nr-acc-pct"><%=a.multi%>%</span>
        </div>
      </div>
    </div>
    <% }); %>
  </div>

  <!-- ══════════════════════════════════════
       ACTIONS
  ══════════════════════════════════════ -->
  <div class="nr-actions">
    <a href="/parameters" class="nr-btn nr-btn-primary">← New Analysis</a>
    <a href="/secrets" class="nr-btn nr-btn-ghost">Random Row Predict</a>
    <a href="/submit" class="nr-btn nr-btn-ghost">Dashboard</a>
  </div>

<% } else { %>

  <!-- ══════════════════════════════════════
       EMPTY STATE (direct GET)
  ══════════════════════════════════════ -->
  <div class="nr-empty">
    <div class="nr-empty-icon">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#71C9CE" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </div>
    <div class="nr-empty-title">No Results Yet</div>
    <div class="nr-empty-sub">Submit the parameter form to run a traffic analysis across all 4 models</div>
    <a href="/parameters" class="nr-btn nr-btn-primary" style="margin-top:20px;">Go to Parameter Input</a>
  </div>

<% } %>

</div>

<%- include('partials/footer') %>
</div>

<!-- ══════════════════════════════════════
     STYLES
══════════════════════════════════════ -->
<style>
.nr-page {
  max-width: 860px;
  margin: 0 auto;
  padding: 32px 20px 60px;
  font-family: "Montserrat", sans-serif;
  color: #fff;
}

/* ── Page header ── */
.nr-header {
  display: flex; align-items: center; gap: 14px;
  margin-bottom: 22px; flex-wrap: wrap;
}
.nr-header-icon {
  width: 46px; height: 46px; border-radius: 12px;
  border: 1px solid;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.nr-icon-danger { background:rgba(248,113,113,0.15);border-color:rgba(248,113,113,0.3);color:#f87171; }
.nr-header-text { flex: 1; min-width: 0; }
.nr-title  { font-size: 20px; font-weight: 700; color:#fff; margin: 0 0 3px; letter-spacing:-0.3px; }
.nr-subtitle { font-size: 13px; color: rgba(255,255,255,0.45); margin: 0; }
.nr-header-actions { display: flex; gap: 8px; }

/* ── Error ── */
.nr-error-card {
  background: rgba(248,113,113,0.07);
  border: 1px solid rgba(248,113,113,0.2);
  border-radius: 12px; padding: 18px 20px; margin-bottom: 18px;
}
.nr-error-label {
  font-size: 10px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: #f87171; margin-bottom: 8px; font-family: monospace;
}
.nr-error-msg { font-size: 13px; color: rgba(255,255,255,0.7); line-height: 1.6; margin: 0; word-break: break-word; }

/* ── Verdict banner ── */
.nr-verdict {
  display: flex; align-items: flex-start; justify-content: space-between;
  flex-wrap: wrap; gap: 20px;
  border: 1px solid; border-radius: 14px;
  padding: 22px 24px; margin-bottom: 14px;
  backdrop-filter: blur(10px);
}
.nr-verdict-left { display: flex; align-items: flex-start; gap: 16px; flex: 1; min-width: 0; }
.nr-verdict-icon {
  width: 52px; height: 52px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.nr-verdict-status { font-size: 20px; font-weight: 700; margin-bottom: 5px; }
.nr-verdict-detail { font-size: 13px; color: rgba(255,255,255,0.55); margin-bottom: 8px; }
.nr-verdict-desc   { font-size: 12px; color: rgba(255,255,255,0.45); line-height: 1.6; max-width: 480px; }

/* Consensus pips */
.nr-vote-block { text-align: right; flex-shrink: 0; }
.nr-vote-label {
  font-size: 10px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.08em; color: rgba(255,255,255,0.35);
  margin-bottom: 8px; font-family: monospace;
}
.nr-vote-pips { display: flex; gap: 6px; justify-content: flex-end; margin-bottom: 6px; }
.nr-pip { width: 32px; height: 7px; border-radius: 99px; transition: all 0.3s; }
.nr-vote-fraction { font-size: 13px; font-weight: 700; margin-bottom: 2px; }
.nr-vote-note     { font-size: 10px; color: rgba(255,255,255,0.35); font-family: monospace; }

/* ── Section label ── */
.nr-section-label {
  display: flex; align-items: center; gap: 8px;
  font-size: 10px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.12em; color: rgba(255,255,255,0.35);
  margin: 22px 0 12px; font-family: monospace;
}

/* ── Model grid ── */
.nr-model-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
@media (max-width: 560px) { .nr-model-grid { grid-template-columns: 1fr; } }

.nr-model-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px; padding: 16px;
  backdrop-filter: blur(8px);
  transition: transform 0.2s, box-shadow 0.2s;
}
.nr-model-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
}

.nr-mc-head { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
.nr-mc-avatar {
  min-width: 40px; height: 40px; border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700; letter-spacing: 0.05em;
  font-family: monospace;
}
.nr-mc-info  { flex: 1; min-width: 0; }
.nr-mc-name  { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.85); margin-bottom: 3px; }
.nr-mc-family {
  display: inline-block; font-size: 9px; font-weight: 700;
  padding: 2px 7px; border-radius: 3px;
  font-family: monospace; letter-spacing: 0.06em;
}
.nr-mc-verdict {
  padding: 4px 10px; border-radius: 99px;
  font-size: 11px; font-weight: 700;
  white-space: nowrap;
}
.nr-mc-divider { height: 1px; background: rgba(255,255,255,0.06); margin-bottom: 12px; }
.nr-mc-row { display: flex; justify-content: space-between; align-items: center; }
.nr-mc-lbl { font-size: 10px; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.07em; font-family: monospace; }
.nr-mc-val { font-size: 12px; font-weight: 600; }

/* Confidence bar */
.nr-mc-conf-bar {
  flex: 1; height: 4px; background: rgba(255,255,255,0.07);
  border-radius: 2px; overflow: hidden; margin: 0 8px;
}
.nr-mc-conf-fill { height: 100%; border-radius: 2px; transition: width 0.8s; }
.nr-mc-conf-pct { font-size: 11px; font-weight: 600; min-width: 36px; text-align: right; font-family: monospace; }

/* Table links */
.nr-mc-links { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px; }
.nr-mc-link {
  font-size: 10px; font-family: monospace; font-weight: 600;
  color: rgba(255,255,255,0.35); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 4px; padding: 4px 9px; text-decoration: none;
  letter-spacing: 0.05em; transition: all 0.15s;
}
.nr-mc-link:hover { border-color: rgba(113,201,206,0.4); color: #71C9CE; }

/* ── Accuracy card ── */
.nr-acc-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px; padding: 4px 0;
  backdrop-filter: blur(8px);
}
.nr-acc-row {
  display: flex; align-items: center; gap: 14px;
  padding: 14px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.nr-acc-row:last-child { border-bottom: none; }
.nr-acc-left { display: flex; flex-direction: column; gap: 3px; width: 80px; flex-shrink: 0; }
.nr-acc-abbr { font-family: monospace; font-size: 12px; font-weight: 700; }
.nr-acc-family { font-size: 9px; color: rgba(255,255,255,0.3); font-family: monospace; }
.nr-acc-bars { flex: 1; display: flex; flex-direction: column; gap: 6px; }
.nr-acc-bar-row { display: flex; align-items: center; gap: 8px; }
.nr-acc-bar-lbl { font-size: 9px; color: rgba(255,255,255,0.3); width: 30px; font-family: monospace; flex-shrink: 0; }
.nr-acc-track { flex: 1; height: 4px; background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden; }
.nr-acc-fill  { height: 100%; border-radius: 2px; }
.nr-acc-pct   { font-size: 10px; font-family: monospace; color: rgba(255,255,255,0.5); width: 38px; text-align: right; flex-shrink: 0; }

/* ── Empty state ── */
.nr-empty {
  display: flex; flex-direction: column; align-items: center;
  text-align: center; padding: 60px 20px;
}
.nr-empty-icon {
  width: 64px; height: 64px; border-radius: 16px;
  background: rgba(0,173,181,0.1); border: 1px solid rgba(0,173,181,0.2);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 16px;
}
.nr-empty-title { font-size: 18px; font-weight: 700; color: #fff; margin-bottom: 8px; }
.nr-empty-sub   { font-size: 13px; color: rgba(255,255,255,0.4); max-width: 360px; line-height: 1.6; }

/* ── Actions ── */
.nr-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 24px; }

/* ── Buttons ── */
.nr-btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 10px 18px; border-radius: 8px;
  font-size: 13px; font-weight: 600;
  font-family: "Montserrat", sans-serif;
  text-decoration: none; cursor: pointer; border: none;
  transition: all 0.18s; white-space: nowrap;
}
.nr-btn-primary { background: #00ADB5; color: #fff; }
