<%- include('partials/header') %>
<%- include('partials/loadhead') %>

<body class="app-body" onload="showPage()">
<div id="loader"></div>

<div id="myDiv" class="animate-bottom" style="display:none;">
<div class="cv-page">

<%
  const totalR   = totalRows;
  const atkPct   = totalR > 0 ? Math.round(attackCount / totalR * 100) : 0;
  const normPct  = totalR > 0 ? Math.round(normalCount / totalR * 100) : 0;
  const modelAcc = model === 'cnn' ? '95%' : model === 'lstm' ? '93%' : model === 'rf' ? '99%' : '97%';
  const bdMax    = Math.max(...Object.values(breakdown), 1);
  const bdColors = {
    Normal: 'var(--safe)',
    Dos:    'var(--danger)',
    Probe:  'var(--warn)',
    R2L:    'var(--purple)',
    U2R:    'var(--orange)'
  };
  const chipCls = {
    Normal: 'chip-normal',
    Dos:    'chip-dos',
    Probe:  'chip-probe',
    R2L:    'chip-r2l',
    U2R:    'chip-u2r'
  };
  const bdDesc = {
    Normal: 'Normal traffic',
    Dos:    'Denial of Service',
    Probe:  'Probe / Scan',
    R2L:    'Remote to Local',
    U2R:    'User to Root'
  };
  const r = 54, circ = 2 * Math.PI * r;
  const safeDash = circ * normPct / 100;
  const atkDash  = circ * atkPct  / 100;

  /* ── Determine overall threat posture from CSV breakdown ── */
  const overallAttack = atkPct >= 50;
  const topType =
    breakdown.Dos    > 0 ? 'DOS'    :
    breakdown.Probe  > 0 ? 'PROBE'  :
    breakdown.R2L    > 0 ? 'R2L'    :
    breakdown.U2R    > 0 ? 'U2R'    : 'NORMAL';

  const COLORS = {
    DOS:    { bg:'rgba(248,113,113,0.12)', accent:'#f87171', border:'rgba(248,113,113,0.25)', text:'rgba(248,113,113,0.9)'  },
    PROBE:  { bg:'rgba(251,191,36,0.12)',  accent:'#fbbf24', border:'rgba(251,191,36,0.25)',  text:'rgba(251,191,36,0.9)'   },
    R2L:    { bg:'rgba(192,132,252,0.12)', accent:'#c084fc', border:'rgba(192,132,252,0.25)', text:'rgba(192,132,252,0.9)'  },
    U2R:    { bg:'rgba(251,146,60,0.12)',  accent:'#fb923c', border:'rgba(251,146,60,0.25)',  text:'rgba(251,146,60,0.9)'   },
    NORMAL: { bg:'rgba(113,201,206,0.10)', accent:'#71C9CE', border:'rgba(113,201,206,0.25)', text:'rgba(113,201,206,0.9)'  }
  };
  const topC = COLORS[overallAttack ? topType : 'NORMAL'];

  /* ── How many distinct attack types appear? (for "vote" pips) ── */
  const attackTypes = ['Dos','Probe','R2L','U2R'].filter(t => breakdown[t] > 0);
  const threatCount = attackTypes.length;

  /* ── Accuracy reference ── */
  const ACC_MAP = {
    cnn:  { abbr:'CNN',  name:'Convolutional Neural Net', family:'Deep Learning', bin:'97.9', multi:'95.1', tc:'var(--blue)'  },
    lstm: { abbr:'LSTM', name:'Long Short-Term Memory',   family:'Deep Learning', bin:'98.7', multi:'96.2', tc:'var(--blue)'  },
    rf:   { abbr:'RF',   name:'Random Forest',            family:'ML Ensemble',   bin:'97.1', multi:'94.3', tc:'var(--safe)'  },
    knn:  { abbr:'KNN',  name:'K-Nearest Neighbour',      family:'ML Instance',   bin:'95.3', multi:'91.8', tc:'var(--safe)'  }
  };
  const accRow = ACC_MAP[model] || ACC_MAP['rf'];
%>

<!-- ══════════════════════════════════════
     PAGE HEADER
══════════════════════════════════════ -->
<div class="cv-header">
  <div class="cv-header-icon" style="background:rgba(0,173,181,0.15);border-color:rgba(0,173,181,0.3);color:#71C9CE;">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
    </svg>
  </div>
  <div class="cv-header-text">
    <h1 class="cv-title">CSV File Analysis Results</h1>
    <p class="cv-subtitle">
      <%= totalR.toLocaleString() %> records analysed &middot;
      <%= model.toUpperCase() %> model &middot;
      <%= modelAcc %> accuracy &middot;
      File: <span style="color:rgba(113,201,206,0.8)"><%= filename %></span>
    </p>
  </div>
  <div class="cv-header-actions">
    <a href="/submit" class="cv-btn cv-btn-ghost">← New Prediction</a>
    <a href="/download/<%= encodeURIComponent(filename) %>" class="cv-btn cv-btn-primary">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      Download CSV
    </a>
  </div>
</div>

<!-- ══════════════════════════════════════
     VERDICT BANNER  (mirrors paramsecrets)
══════════════════════════════════════ -->
<div class="cv-verdict" style="background:<%=topC.bg%>;border-color:<%=topC.border%>;">

  <div class="cv-verdict-left">
    <div class="cv-verdict-icon" style="background:<%=topC.bg%>;border:1px solid <%=topC.border%>;">
      <% if (overallAttack) { %>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="<%= topC.accent %>" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
      <% } else { %>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="<%= topC.accent %>" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <polyline points="9 12 11 14 15 10"/>
        </svg>
      <% } %>
    </div>

    <div>
      <div class="cv-verdict-status" style="color:<%=topC.text%>;">
        <%= overallAttack ? 'Threats Detected in Dataset' : 'Dataset Appears Clean' %>
      </div>
      <div class="cv-verdict-detail">
        <% if (overallAttack) { %>
          <%= atkPct %>% of traffic flagged &mdash;
          <span style="color:<%=topC.text%>;font-weight:700;"><%= attackCount.toLocaleString() %> malicious records</span>
          detected by <%= model.toUpperCase() %>
        <% } else { %>
          <%= normPct %>% normal traffic &mdash; no significant threat patterns found
        <% } %>
      </div>
      <% if (overallAttack && attackTypes.length > 0) { %>
        <div class="cv-verdict-types">
          <% attackTypes.forEach(function(t) { %>
            <span class="cv-type-tag cv-tag-<%= t.toLowerCase() %>"><%= t.toUpperCase() %></span>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Right: breakdown pips by attack type -->
  <div class="cv-vote-block">
    <div class="cv-vote-label">Attack Categories</div>
    <div class="cv-vote-pips">
      <% const PIPTYPES = ['Dos','Probe','R2L','U2R'];
         PIPTYPES.forEach(function(t, i) {
           const has = breakdown[t] > 0;
           const pipAccents = { Dos:'#f87171', Probe:'#fbbf24', R2L:'#c084fc', U2R:'#fb923c' };
           const pa = pipAccents[t];
      %>
        <div class="cv-pip" style="
          background: <%= has ? pa : 'rgba(255,255,255,0.10)' %>;
          box-shadow: <%= has ? '0 0 8px ' + pa + '88' : 'none' %>;
          " title="<%= t %>"></div>
      <% }); %>
    </div>
    <div class="cv-vote-fraction" style="color:<%=topC.text%>;">
      <%= threatCount %> of 4 types
    </div>
    <div class="cv-vote-note"><%= overallAttack ? 'Mixed threat profile' : 'No attack types' %></div>
  </div>

</div>

<!-- ══════════════════════════════════════
     STATS ROW  (4 cards)
══════════════════════════════════════ -->
<div class="cv-section-label">
  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
  Summary Statistics
</div>

<div class="cv-stats-grid">
  <div class="cv-stat-card cv-s-total">
    <div class="cv-stat-icon">
      <svg viewBox="0 0 24 24"><path d="M3 3h7v7H3z"/><path d="M14 3h7v7h-7z"/><path d="M14 14h7v7h-7z"/><path d="M3 14h7v7H3z"/></svg>
    </div>
    <div class="cv-stat-label">Total Records</div>
    <div class="cv-stat-value"><%= totalR.toLocaleString() %></div>
    <div class="cv-stat-sub">Rows processed</div>
  </div>
  <div class="cv-stat-card cv-s-normal">
    <div class="cv-stat-icon">
      <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    </div>
    <div class="cv-stat-label">Normal Traffic</div>
    <div class="cv-stat-value"><%= normalCount.toLocaleString() %></div>
    <div class="cv-stat-sub"><%= normPct %>% of total</div>
  </div>
  <div class="cv-stat-card cv-s-attack">
    <div class="cv-stat-icon">
      <svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    </div>
    <div class="cv-stat-label">Threats Detected</div>
    <div class="cv-stat-value"><%= attackCount.toLocaleString() %></div>
    <div class="cv-stat-sub"><%= atkPct %>% of total</div>
  </div>
  <div class="cv-stat-card cv-s-model">
    <div class="cv-stat-icon">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
    </div>
    <div class="cv-stat-label">Model Used</div>
    <div class="cv-stat-value cv-model-name"><%= model.toUpperCase() %></div>
    <div class="cv-stat-sub">Accuracy: <%= modelAcc %></div>
  </div>
</div>

<!-- ══════════════════════════════════════
     CHARTS ROW  (donut + bar)
══════════════════════════════════════ -->
<div class="cv-section-label">
  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5"><circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 10 10"/></svg>
  Classification Breakdown
</div>

<div class="cv-two-col">

  <!-- Donut: binary -->
  <div class="cv-card">
    <div class="cv-card-head">
      <div class="cv-card-head-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 10 10"/></svg>
      </div>
      <span class="cv-card-title">Binary Classification</span>
    </div>
    <div class="cv-card-body">
      <div class="cv-donut-wrap">
        <div class="cv-donut-svg-wrap">
          <svg width="140" height="140" viewBox="0 0 140 140">
            <circle cx="70" cy="70" r="54" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="16"/>
            <circle cx="70" cy="70" r="54" fill="none" stroke="#71C9CE" stroke-width="16"
              stroke-dasharray="<%= safeDash.toFixed(2) %> <%= circ.toFixed(2) %>"
              stroke-dashoffset="0" transform="rotate(-90 70 70)"/>
            <circle cx="70" cy="70" r="54" fill="none" stroke="#f87171" stroke-width="16"
              stroke-dasharray="<%= atkDash.toFixed(2) %> <%= circ.toFixed(2) %>"
              stroke-dashoffset="<%= (-safeDash).toFixed(2) %>" transform="rotate(-90 70 70)"/>
          </svg>
          <div class="cv-donut-center">
            <div class="cv-donut-pct" style="color:<%= atkPct > 50 ? '#f87171' : '#71C9CE' %>"><%= atkPct %>%</div>
            <div class="cv-donut-sub">attacks</div>
          </div>
        </div>
        <div class="cv-donut-legend">
          <div class="cv-legend-item">
            <div class="cv-legend-dot" style="background:#71C9CE"></div>
            <span class="cv-legend-name">Normal</span>
            <span class="cv-legend-val"><%= normalCount.toLocaleString() %></span>
            <span class="cv-legend-pct">(<%= normPct %>%)</span>
          </div>
          <div class="cv-legend-item">
            <div class="cv-legend-dot" style="background:#f87171"></div>
            <span class="cv-legend-name">Attack</span>
            <span class="cv-legend-val"><%= attackCount.toLocaleString() %></span>
            <span class="cv-legend-pct">(<%= atkPct %>%)</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bar chart: multi-class distribution -->
  <div class="cv-card">
    <div class="cv-card-head">
      <div class="cv-card-head-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      </div>
      <span class="cv-card-title">Attack Distribution</span>
    </div>
    <div class="cv-card-body">
      <div class="cv-bar-list">
        <% Object.entries(breakdown).forEach(([type, count]) => {
          const pct = Math.round(count / bdMax * 100);
          const col = bdColors[type] || 'var(--muted)';
        %>
        <div class="cv-bar-item">
          <div class="cv-bar-meta">
            <span class="cv-bar-name">
              <span class="cv-bar-dot" style="background:<%= col %>"></span>
              <%= type %>
            </span>
            <span class="cv-bar-count">
              <%= count.toLocaleString() %>
              <span class="cv-bar-pct">(<%= totalR > 0 ? Math.round(count/totalR*100) : 0 %>%)</span>
            </span>
          </div>
          <div class="cv-bar-track">
            <div class="cv-bar-fill" style="width:<%= pct %>%;background:<%= col %>;"></div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     MULTI-CLASS CHIPS
══════════════════════════════════════ -->
<div class="cv-section-label">
  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
  Multi-class Breakdown
</div>

<div class="cv-card">
  <div class="cv-card-body">
    <div class="cv-chips-grid">
      <% Object.entries(breakdown).forEach(([type, count]) => { %>
      <div class="cv-chip <%= chipCls[type] || '' %>">
        <div class="cv-chip-num"><%= count.toLocaleString() %></div>
        <div class="cv-chip-label"><%= type %></div>
        <div class="cv-chip-sub"><%= bdDesc[type] || '' %></div>
      </div>
      <% }); %>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     MODEL ACCURACY REFERENCE  (mirrors paramsecrets)
══════════════════════════════════════ -->
<div class="cv-section-label">
  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
  Model Accuracy Reference &middot; NSL-KDD Test Set
</div>

<div class="cv-acc-card">
  <%
    const ALL_ACC = [
      { abbr:'LSTM', name:'Long Short-Term Memory', family:'Deep Learning', bin:'98.7', multi:'96.2', tc:'var(--blue)'  },
      { abbr:'CNN',  name:'Convolutional Neural Net',family:'Deep Learning', bin:'97.9', multi:'95.1', tc:'var(--blue)'  },
      { abbr:'RF',   name:'Random Forest',           family:'ML Ensemble',  bin:'97.1', multi:'94.3', tc:'var(--safe)'  },
      { abbr:'KNN',  name:'K-Nearest Neighbour',     family:'ML Instance',  bin:'95.3', multi:'91.8', tc:'var(--safe)'  }
    ];
  %>
  <% ALL_ACC.forEach(function(a) { %>
  <div class="cv-acc-row <%= a.abbr.toLowerCase() === model ? 'cv-acc-active' : '' %>">
    <div class="cv-acc-left">
      <span class="cv-acc-abbr" style="color:<%=a.tc%>;"><%=a.abbr%></span>
      <span class="cv-acc-family"><%=a.family%></span>
    </div>
    <div class="cv-acc-bars">
      <div class="cv-acc-bar-row">
        <span class="cv-acc-bar-lbl">Binary</span>
        <div class="cv-acc-track">
          <div class="cv-acc-fill" style="width:<%=a.bin%>%;background:<%=a.tc%>;"></div>
        </div>
        <span class="cv-acc-pct"><%=a.bin%>%</span>
      </div>
      <div class="cv-acc-bar-row">
        <span class="cv-acc-bar-lbl">Multi</span>
        <div class="cv-acc-track">
          <div class="cv-acc-fill" style="width:<%=a.multi%>%;background:<%=a.tc%>;opacity:0.55;"></div>
        </div>
        <span class="cv-acc-pct"><%=a.multi%>%</span>
      </div>
    </div>
    <% if (a.abbr.toLowerCase() === model) { %>
      <span class="cv-acc-active-tag">Active</span>
    <% } %>
  </div>
  <% }); %>
</div>

<!-- ══════════════════════════════════════
     DATA TABLE
══════════════════════════════════════ -->
<div class="cv-section-label">
  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
  Detailed Results
</div>

<div class="cv-table-card">
  <div class="cv-table-head">
    <div class="cv-table-head-left">
      <span class="cv-card-title">Row-level Predictions</span>
      <span class="cv-row-badge" id="rowCountBadge"><%= rows.length.toLocaleString() %> rows</span>
    </div>
    <div class="cv-table-controls">
      <div class="cv-search-wrap">
        <svg class="cv-search-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="cv-t-search" type="text" id="searchInput" placeholder="Search rows…" oninput="filterTable()"/>
      </div>
      <select class="cv-t-filter" id="filterSelect" onchange="filterTable()">
        <option value="">All types</option>
        <option value="normal">Normal</option>
        <option value="attack">Attack</option>
        <option value="dos">DoS</option>
        <option value="probe">Probe</option>
        <option value="r2l">R2L</option>
        <option value="u2r">U2R</option>
      </select>
    </div>
  </div>
  <div class="cv-table-scroll">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Protocol</th>
          <th>Service</th>
          <th>Flag</th>
          <th>Logged In</th>
          <th>Count</th>
          <th>Same Srv Rate</th>
          <th>Dst Host Cnt</th>
          <th>Dst Srv Cnt</th>
          <th>Binary</th>
          <th>Multi-class</th>
        </tr>
      </thead>
      <tbody id="tableBody">
        <% rows.forEach((row, idx) => {
          const bin  = (row['binary class'] || '').trim();
          const multi= (row['multi class']  || '').trim();
          const binC = bin.toLowerCase();
          const mulC = multi.toLowerCase();
        %>
        <tr data-bin="<%= binC %>" data-multi="<%= mulC %>">
          <td class="cv-row-idx"><%= idx + 1 %></td>
          <td><%= row.protocol_type      || '—' %></td>
          <td><%= row.service            || '—' %></td>
          <td><%= row.flag               || '—' %></td>
          <td><%= row.logged_in          || '—' %></td>
          <td><%= row.count              || '—' %></td>
          <td><%= row.same_srv_rate      || '—' %></td>
          <td><%= row.dst_host_count     || '—' %></td>
          <td><%= row.dst_host_srv_count || '—' %></td>
          <td><span class="cv-badge cv-badge-<%= binC %>"><%= bin || '—' %></span></td>
          <td><span class="cv-badge cv-badge-<%= mulC %>"><%= multi || '—' %></span></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <div class="cv-table-footer">
    <span id="pageInfo"></span>
    <div class="cv-page-btns" id="pageBtns"></div>
  </div>
</div>

<!-- ── Actions ── -->
<div class="cv-actions">
  <a href="/submit" class="cv-btn cv-btn-primary">← New Prediction</a>
  <a href="/parameters" class="cv-btn cv-btn-ghost">Manual Parameters</a>
  <a href="/secrets" class="cv-btn cv-btn-ghost">Random Row</a>
</div>

</div><!-- /cv-page -->

<%- include('partials/footer') %>
</div><!-- /myDiv -->

<!-- ══════════════════════════════════════
     STYLES
══════════════════════════════════════ -->
<style>
/* ── Tokens (matching paramsecrets palette) ── */
:root {
  --bg:        #0a0e17;
  --surface:   #111827;
  --card:      rgba(255,255,255,0.045);
  --border:    rgba(255,255,255,0.08);
  --border2:   rgba(255,255,255,0.12);
  --accent:    #71C9CE;
  --accent-d:  #00ADB5;
  --text:      rgba(255,255,255,0.9);
  --muted:     rgba(255,255,255,0.35);
  --muted2:    rgba(255,255,255,0.55);
  --safe:      #71C9CE;
  --safe-bg:   rgba(113,201,206,0.12);
  --safe-bd:   rgba(113,201,206,0.25);
  --danger:    #f87171;
  --danger-bg: rgba(248,113,113,0.12);
  --danger-bd: rgba(248,113,113,0.25);
  --warn:      #fbbf24;
  --warn-bg:   rgba(251,191,36,0.12);
  --warn-bd:   rgba(251,191,36,0.25);
  --purple:    #c084fc;
  --purple-bg: rgba(192,132,252,0.12);
  --purple-bd: rgba(192,132,252,0.25);
  --orange:    #fb923c;
  --orange-bg: rgba(251,146,60,0.12);
  --orange-bd: rgba(251,146,60,0.25);
  --blue:      #24a0ed;
  --font: "Montserrat", sans-serif;
  --mono: "JetBrains Mono", "Fira Mono", monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── Page wrapper ── */
.cv-page {
  max-width: 860px;
  margin: 0 auto;
  padding: 32px 20px 60px;
  font-family: var(--font);
  color: var(--text);
}

/* ── Page header ── */
.cv-header {
  display: flex; align-items: center; gap: 14px;
  margin-bottom: 22px; flex-wrap: wrap;
}
.cv-header-icon {
  width: 46px; height: 46px; border-radius: 12px;
  border: 1px solid;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.cv-header-text { flex: 1; min-width: 0; }
.cv-title    { font-size: 20px; font-weight: 700; color: #fff; margin: 0 0 3px; letter-spacing: -0.3px; }
.cv-subtitle { font-size: 13px; color: var(--muted2); margin: 0; }
.cv-header-actions { display: flex; gap: 8px; }

/* ── Verdict banner ── */
.cv-verdict {
  display: flex; align-items: flex-start; justify-content: space-between;
  flex-wrap: wrap; gap: 20px;
  border: 1px solid; border-radius: 14px;
  padding: 22px 24px; margin-bottom: 14px;
  backdrop-filter: blur(10px);
}
.cv-verdict-left  { display: flex; align-items: flex-start; gap: 16px; flex: 1; min-width: 0; }
.cv-verdict-icon  {
  width: 52px; height: 52px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.cv-verdict-status { font-size: 20px; font-weight: 700; margin-bottom: 5px; }
.cv-verdict-detail { font-size: 13px; color: var(--muted2); margin-bottom: 8px; }
.cv-verdict-types  { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }

/* attack type tags under verdict */
.cv-type-tag {
  font-size: 10px; font-weight: 700; letter-spacing: 0.07em;
  padding: 3px 9px; border-radius: 4px; font-family: var(--mono);
}
.cv-tag-dos   { background: var(--danger-bg); color: var(--danger); border: 1px solid var(--danger-bd); }
.cv-tag-probe { background: var(--warn-bg);   color: var(--warn);   border: 1px solid var(--warn-bd);   }
.cv-tag-r2l   { background: var(--purple-bg); color: var(--purple); border: 1px solid var(--purple-bd); }
.cv-tag-u2r   { background: var(--orange-bg); color: var(--orange); border: 1px solid var(--orange-bd); }

/* Consensus pips block */
.cv-vote-block { text-align: right; flex-shrink: 0; }
.cv-vote-label {
  font-size: 10px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--muted);
  margin-bottom: 8px; font-family: var(--mono);
}
.cv-vote-pips    { display: flex; gap: 6px; justify-content: flex-end; margin-bottom: 6px; }
.cv-pip          { width: 32px; height: 7px; border-radius: 99px; transition: all 0.3s; }
.cv-vote-fraction { font-size: 13px; font-weight: 700; margin-bottom: 2px; }
.cv-vote-note    { font-size: 10px; color: var(--muted); font-family: var(--mono); }

/* ── Section label ── */
.cv-section-label {
  display: flex; align-items: center; gap: 8px;
  font-size: 10px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.12em; color: var(--muted);
  margin: 22px 0 12px; font-family: var(--mono);
}

/* ── Stats grid ── */
.cv-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  margin-bottom: 0;
}
@media (max-width: 700px) { .cv-stats-grid { grid-template-columns: repeat(2, 1fr); } }

.cv-stat-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px; padding: 16px;
  position: relative; overflow: hidden;
  transition: transform 0.2s;
}
.cv-stat-card:hover { transform: translateY(-2px); }
.cv-stat-card::after { content:''; position:absolute; bottom:0; left:0; right:0; height:2px; }
.cv-s-total::after  { background: linear-gradient(90deg, var(--accent), transparent); }
.cv-s-normal::after { background: linear-gradient(90deg, var(--safe),   transparent); }
.cv-s-attack::after { background: linear-gradient(90deg, var(--danger), transparent); }
.cv-s-model::after  { background: linear-gradient(90deg, var(--warn),   transparent); }

.cv-stat-icon {
  width: 30px; height: 30px; border-radius: 8px;
  display: grid; place-items: center; margin-bottom: 12px;
}
.cv-stat-icon svg { width: 14px; height: 14px; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
.cv-s-total  .cv-stat-icon { background: rgba(113,201,206,0.12); } .cv-s-total  .cv-stat-icon svg { stroke: var(--accent); }
.cv-s-normal .cv-stat-icon { background: rgba(113,201,206,0.12); } .cv-s-normal .cv-stat-icon svg { stroke: var(--safe);   }
.cv-s-attack .cv-stat-icon { background: rgba(248,113,113,0.12); } .cv-s-attack .cv-stat-icon svg { stroke: var(--danger); }
.cv-s-model  .cv-stat-icon { background: rgba(251,191,36,0.12);  } .cv-s-model  .cv-stat-icon svg { stroke: var(--warn);   }

.cv-stat-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--muted); margin-bottom: 4px; font-family: var(--mono); }
.cv-stat-value { font-size: 24px; font-weight: 700; font-family: var(--mono); line-height: 1; letter-spacing: -0.03em; }
.cv-model-name { font-size: 16px !important; margin-top: 4px; }
.cv-s-total  .cv-stat-value { color: var(--accent); }
.cv-s-normal .cv-stat-value { color: var(--safe);   }
.cv-s-attack .cv-stat-value { color: var(--danger); }
.cv-s-model  .cv-stat-value { color: var(--warn);   }
.cv-stat-sub { font-size: 11px; color: var(--muted); margin-top: 5px; }

/* ── Two-col row ── */
.cv-two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
@media (max-width: 620px) { .cv-two-col { grid-template-columns: 1fr; } }

/* ── Generic card ── */
.cv-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px; overflow: hidden;
  backdrop-filter: blur(8px);
  transition: transform 0.2s, box-shadow 0.2s;
}
.cv-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
.cv-card-head {
  display: flex; align-items: center; gap: 8px;
  padding: 13px 16px;
  border-bottom: 1px solid var(--border);
}
.cv-card-head-icon {
  width: 26px; height: 26px; border-radius: 6px;
  background: rgba(0,173,181,0.1);
  display: grid; place-items: center;
}
.cv-card-head-icon svg { width: 13px; height: 13px; }
.cv-card-title { font-size: 13px; font-weight: 600; color: var(--text); }
.cv-card-body  { padding: 16px; }

/* ── Donut ── */
.cv-donut-wrap     { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
.cv-donut-svg-wrap { position: relative; width: 140px; height: 140px; flex-shrink: 0; }
.cv-donut-center   { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.cv-donut-pct      { font-size: 20px; font-weight: 700; font-family: var(--mono); }
.cv-donut-sub      { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
.cv-donut-legend   { display: flex; flex-direction: column; gap: 10px; flex: 1; min-width: 110px; }
.cv-legend-item    { display: flex; align-items: center; gap: 8px; }
.cv-legend-dot     { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.cv-legend-name    { font-size: 12px; color: var(--muted2); flex: 1; }
.cv-legend-val     { font-size: 12px; font-family: var(--mono); font-weight: 500; }
.cv-legend-pct     { font-size: 11px; color: var(--muted); margin-left: 2px; }

/* ── Bar list ── */
.cv-bar-list { display: flex; flex-direction: column; gap: 13px; }
.cv-bar-meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }
.cv-bar-name { font-size: 12px; font-weight: 500; color: var(--muted2); display: flex; align-items: center; gap: 6px; }
.cv-bar-dot  { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.cv-bar-count { font-size: 12px; font-family: var(--mono); }
.cv-bar-pct   { font-size: 10px; color: var(--muted); margin-left: 4px; }
.cv-bar-track { height: 5px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden; }
.cv-bar-fill  { height: 100%; border-radius: 3px; opacity: 0.75; transition: width 0.6s ease; }

/* ── Chips ── */
.cv-chips-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
  gap: 10px;
}
.cv-chip {
  display: flex; flex-direction: column; align-items: center;
  gap: 3px; padding: 14px 8px;
  border-radius: 10px; border: 1px solid;
  text-align: center; transition: transform 0.15s;
}
.cv-chip:hover { transform: translateY(-2px); }
.cv-chip-num   { font-size: 20px; font-weight: 700; font-family: var(--mono); line-height: 1; }
.cv-chip-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; margin-top: 2px; }
.cv-chip-sub   { font-size: 10px; opacity: 0.55; margin-top: 1px; }
.chip-normal { background: var(--safe-bg);   border-color: var(--safe-bd);   color: var(--safe);   }
.chip-dos    { background: var(--danger-bg); border-color: var(--danger-bd); color: var(--danger); }
.chip-probe  { background: var(--warn-bg);   border-color: var(--warn-bd);   color: var(--warn);   }
.chip-r2l    { background: var(--purple-bg); border-color: var(--purple-bd); color: var(--purple); }
.chip-u2r    { background: var(--orange-bg); border-color: var(--orange-bd); color: var(--orange); }

/* ── Accuracy card  (identical to paramsecrets) ── */
.cv-acc-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px; padding: 4px 0;
  backdrop-filter: blur(8px);
}
.cv-acc-row {
  display: flex; align-items: center; gap: 14px;
  padding: 14px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  transition: background 0.15s;
}
.cv-acc-row:last-child  { border-bottom: none; }
.cv-acc-row:hover       { background: rgba(255,255,255,0.03); }
.cv-acc-active          { background: rgba(113,201,206,0.05) !important; }
.cv-acc-active-tag {
  font-size: 9px; font-weight: 700; letter-spacing: 0.08em;
  padding: 3px 8px; border-radius: 4px;
  background: rgba(113,201,206,0.15); color: var(--accent);
  border: 1px solid rgba(113,201,206,0.25);
  font-family: var(--mono); flex-shrink: 0;
}
.cv-acc-left   { display: flex; flex-direction: column; gap: 3px; width: 80px; flex-shrink: 0; }
.cv-acc-abbr   { font-family: var(--mono); font-size: 12px; font-weight: 700; }
.cv-acc-family { font-size: 9px; color: var(--muted); font-family: var(--mono); }
.cv-acc-bars   { flex: 1; display: flex; flex-direction: column; gap: 6px; }
.cv-acc-bar-row { display: flex; align-items: center; gap: 8px; }
.cv-acc-bar-lbl { font-size: 9px; color: var(--muted); width: 30px; font-family: var(--mono); flex-shrink: 0; }
.cv-acc-track   { flex: 1; height: 4px; background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden; }
.cv-acc-fill    { height: 100%; border-radius: 2px; transition: width 0.8s ease; }
.cv-acc-pct     { font-size: 10px; font-family: var(--mono); color: var(--muted2); width: 38px; text-align: right; flex-shrink: 0; }

/* ── Table card ── */
.cv-table-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px; overflow: hidden;
  backdrop-filter: blur(8px);
}
.cv-table-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 16px; border-bottom: 1px solid var(--border);
  flex-wrap: wrap; gap: 10px;
}
.cv-table-head-left { display: flex; align-items: center; gap: 8px; }
.cv-row-badge {
  font-size: 11px; font-weight: 600;
  padding: 3px 8px; border-radius: 20px;
  background: rgba(0,173,181,0.1); color: var(--accent);
  border: 1px solid rgba(0,173,181,0.2);
}
.cv-table-controls { display: flex; gap: 8px; align-items: center; }
.cv-search-wrap    { position: relative; }
.cv-search-icon    {
  position: absolute; left: 9px; top: 50%; transform: translateY(-50%);
  width: 13px; height: 13px; opacity: 0.35; pointer-events: none;
  fill: none; stroke: var(--text); stroke-width: 2; stroke-linecap: round;
}
.cv-t-search {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border2); border-radius: 7px;
  padding: 6px 10px 6px 29px;
  color: var(--text); font-family: var(--font); font-size: 12px;
  outline: none; width: 175px; transition: border-color 0.15s;
}
.cv-t-search:focus { border-color: var(--accent); background: rgba(0,173,181,0.04); }
.cv-t-filter {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border2); border-radius: 7px;
  padding: 6px 8px;
  color: var(--text); font-family: var(--font); font-size: 12px;
  outline: none; cursor: pointer;
  appearance: none; -webkit-appearance: none;
}
.cv-t-filter:focus { border-color: var(--accent); }
.cv-table-scroll   { overflow-x: auto; max-height: 420px; overflow-y: auto; }

/* scrollbar */
.cv-table-scroll::-webkit-scrollbar { width: 5px; height: 5px; }
.cv-table-scroll::-webkit-scrollbar-track { background: transparent; }
.cv-table-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }

table { width: 100%; border-collapse: collapse; font-size: 12px; }
thead th {
  position: sticky; top: 0; z-index: 2;
  background: #0d1623;
  padding: 9px 14px; text-align: left;
  font-size: 10px; font-weight: 600; color: var(--muted);
  text-transform: uppercase; letter-spacing: 0.06em;
  border-bottom: 1px solid var(--border); white-space: nowrap;
  font-family: var(--mono);
}
tbody tr { border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.1s; }
tbody tr:last-child { border-bottom: none; }
tbody tr:hover { background: rgba(113,201,206,0.04); }
tbody td { padding: 8px 14px; color: var(--text); font-family: var(--mono); white-space: nowrap; font-size: 12px; }
.cv-row-idx { color: var(--muted); font-size: 11px; }

/* badges */
.cv-badge {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 2px 8px; border-radius: 20px;
  font-size: 11px; font-weight: 600;
  font-family: var(--font); white-space: nowrap; border: 1px solid;
}
.cv-badge::before { content:''; width:5px; height:5px; border-radius:50%; background:currentColor; opacity:0.7; flex-shrink:0; }
.cv-badge-normal { background: var(--safe-bg);   color: var(--safe);   border-color: var(--safe-bd);   }
.cv-badge-attack { background: var(--danger-bg); color: var(--danger); border-color: var(--danger-bd); }
.cv-badge-dos    { background: var(--danger-bg); color: var(--danger); border-color: var(--danger-bd); }
.cv-badge-probe  { background: var(--warn-bg);   color: var(--warn);   border-color: var(--warn-bd);   }
.cv-badge-r2l    { background: var(--purple-bg); color: var(--purple); border-color: var(--purple-bd); }
.cv-badge-u2r    { background: var(--orange-bg); color: var(--orange); border-color: var(--orange-bd); }

/* table footer + pagination */
.cv-table-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 16px; border-top: 1px solid var(--border);
  font-size: 12px; color: var(--muted2);
  flex-wrap: wrap; gap: 8px;
}
.cv-page-btns { display: flex; gap: 4px; }
.cv-page-btn {
  min-width: 28px; height: 28px; padding: 0 6px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border); border-radius: 6px;
  color: var(--muted2); font-family: var(--font); font-size: 12px;
  cursor: pointer; transition: all 0.15s;
}
.cv-page-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); background: rgba(113,201,206,0.08); }
.cv-page-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(113,201,206,0.12); font-weight: 600; }
.cv-page-btn:disabled { opacity: 0.3; cursor: not-allowed; }

/* ── Actions row ── */
.cv-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 24px; }

/* ── Buttons ── */
.cv-btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 10px 18px; border-radius: 8px;
  font-size: 13px; font-weight: 600;
  font-family: var(--font);
  text-decoration: none; cursor: pointer; border: none;
  transition: all 0.18s; white-space: nowrap;
}
.cv-btn-primary { background: #00ADB5; color: #fff; }
.cv-btn-primary:hover { background: #00c4cd; box-shadow: 0 0 18px rgba(0,173,181,0.35); color: #fff; }
.cv-btn-ghost {
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.6);
  border: 1px solid rgba(255,255,255,0.1);
}
.cv-btn-ghost:hover { background: rgba(255,255,255,0.1); color: #fff; }

/* ── Fade-in animation ── */
@keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
.cv-verdict      { animation: fadeUp 0.35s ease 0.05s both; }
.cv-stats-grid   { animation: fadeUp 0.35s ease 0.10s both; }
.cv-two-col      { animation: fadeUp 0.35s ease 0.15s both; }
.cv-chips-grid   { animation: fadeUp 0.35s ease 0.20s both; }
.cv-acc-card     { animation: fadeUp 0.35s ease 0.25s both; }
.cv-table-card   { animation: fadeUp 0.35s ease 0.30s both; }
</style>

<!-- ══════════════════════════════════════
     SCRIPTS
══════════════════════════════════════ -->
<script>
function showPage() {
  document.getElementById("loader").style.display = "none";
  document.getElementById("myDiv").style.display  = "block";
}

/* ── Table filter + pagination ── */
const PER_PAGE = 50;
let page = 1, visible = [];

function filterTable() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const f = document.getElementById('filterSelect').value.toLowerCase();
  const all = Array.from(document.querySelectorAll('#tableBody tr'));
  visible = all.filter(tr => {
    const matchQ = !q || tr.textContent.toLowerCase().includes(q);
    const matchF = !f || (tr.dataset.bin||'').includes(f) || (tr.dataset.multi||'').includes(f);
    return matchQ && matchF;
  });
  document.getElementById('rowCountBadge').textContent = visible.length.toLocaleString() + ' rows';
  page = 1;
  render();
}

function render() {
  Array.from(document.querySelectorAll('#tableBody tr')).forEach(r => r.style.display = 'none');
  const start = (page - 1) * PER_PAGE, end = start + PER_PAGE;
  visible.slice(start, end).forEach(r => r.style.display = '');
  const total = visible.length, pages = Math.ceil(total / PER_PAGE) || 1;
  document.getElementById('pageInfo').textContent =
    total === 0 ? 'No results' :
    `${(start+1).toLocaleString()}–${Math.min(end, total).toLocaleString()} of ${total.toLocaleString()}`;

  const btns = document.getElementById('pageBtns');
  btns.innerHTML = '';
  if (pages <= 1) return;

  const mk = (lbl, pg, act, dis) => {
    const b = document.createElement('button');
    b.className = 'cv-page-btn' + (act ? ' active' : '');
    b.textContent = lbl; b.disabled = dis;
    if (!dis) b.onclick = () => { page = pg; render(); };
    return b;
  };
  btns.appendChild(mk('‹', page - 1, false, page === 1));
  let lo = Math.max(1, page - 3), hi = Math.min(pages, lo + 6);
  if (hi - lo < 6) lo = Math.max(1, hi - 6);
  for (let i = lo; i <= hi; i++) btns.appendChild(mk(i, i, i === page, false));
  btns.appendChild(mk('›', page + 1, false, page === pages));
}

visible = Array.from(document.querySelectorAll('#tableBody tr'));
render();
</script>

<%- include('partials/loadfoot') %>
</body>
